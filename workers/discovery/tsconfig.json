{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext"],
    "types": ["@cloudflare/workers-types", "bun"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "paths": {
      "@buildinternet/releases-api-types": ["../../packages/api-types/src/api-types.ts"],
      "@buildinternet/releases-core/*": ["../../packages/core/src/*"],
      "@buildinternet/releases-lib/*": ["../../packages/lib/src/*"],
      "@releases/core-internal/*": ["../../packages/core-internal/src/*"],
      "@releases/ai-internal/*": ["../../packages/ai/src/*"],
      "@releases/adapters/*": ["../../packages/adapters/src/*"],
      "@releases/lib/*": ["../../packages/lib/src/*"],
      "@releases/rendering/*": ["../../packages/rendering/src/*"],
      "@releases/search/*": ["../../packages/search/src/*"],
      "@releases/shared/*": ["../../managed-agents/src/shared/*"]
    }
  },
  "include": ["src/**/*.ts", "test/**/*.ts", "../../managed-agents/src/shared/**/*.ts"]
}
