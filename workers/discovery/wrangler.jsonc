{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "releases-discovery",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-27",
  "compatibility_flags": ["nodejs_compat"],
  "alias": {
    "@releases": "../../src",
    "bun:sqlite": "./src/stubs/bun-sqlite.ts",
  },
  "observability": {
    "enabled": true,
    "logs": {
      "enabled": true,
      "destinations": ["axiom-logs"],
    },
    "traces": {
      "enabled": true,
      "destinations": ["axiom-traces"],
    },
  },
  "vars": {
    "RELEASES_API_URL": "https://api.releases.sh",
    "ANTHROPIC_AGENT_ID": "agent_011CZtWpasPtsYjF3aysf2ZH",
    "ANTHROPIC_ENVIRONMENT_ID": "env_01Tq7S8F2FK1KBz68NMje2RU",
    "ANTHROPIC_VAULT_ID": "vlt_011CZvFkwFPgCkGqRqP87AKB",
    "ANTHROPIC_WORKER_AGENT_ID": "agent_011CZvdgPKDQ2eRs8gTrLnNA",
    // Routes onboard sessions through the multi-agent coordinator (Sonnet)
    // that delegates fetches to the worker agent. Clear this var to fall
    // back to single-agent discovery. See workers/discovery/src/managed-
    // agents-session.ts for the routing logic.
    "ANTHROPIC_COORDINATOR_AGENT_ID": "agent_011Can9iMPcPuLy3oEgjGCs6",
    // Memory stores attached to every session (#537). IDs created via
    // `bun scripts/sync-agent-skills.ts --memory-stores`.
    "MEMORY_STORE_ERRATA_ID": "memstore_012MKStcUM7QxW9qPCLQtwwt",
    "MEMORY_STORE_TOOL_NOTES_ID": "memstore_01Jc5WAiqp4fwSJUmjR2excj",
    // Route direct Anthropic SDK calls (extract-deps + managed-agents-session
    // request helpers) through Cloudflare AI Gateway. The managed-agents
    // internal loop runs on Anthropic's infra and stays off-gateway.
    // See docs/architecture/ai-gateway.md. Gateway runs in authenticated mode.
    "ANTHROPIC_BASE_URL": "https://gateway.ai.cloudflare.com/v1/b082600d280d44fd5da3501bc1bffe2f/releases/anthropic",
    "WEB_BOT_AUTH_ENABLED": "true",
    // Capture the scraped markdown body as a raw snapshot for later
    // re-extraction (#1283/#1284). Flagship key `raw-snapshot-capture-enabled`
    // overrides this var when present. Default off pending rollout.
    "RAW_SNAPSHOT_CAPTURE_ENABLED": "false",
    // OpenRouter extraction lane (issue #1536). Empty → the large-body tool-loop
    // stays on Anthropic regardless of the `openrouter-enabled` flag. Set to an
    // OpenRouter model id (e.g. "deepseek/deepseek-v4-pro") to route extraction
    // there. OPENROUTER_API_KEY is bound below; the resolver still fails open to
    // Anthropic unless the flag is on AND this var is non-empty.
    // Set to deepseek-v4-pro after the extraction eval showed corpus-wide parity
    // with Sonnet-4.6 (issue #1536); reasoning is disabled in the OpenRouter model.
    "EXTRACT_MODEL": "deepseek/deepseek-v4-pro",
  },
  "containers": [
    {
      "class_name": "Sandbox",
      "image": "./Dockerfile",
      "image_build_context": "../../",
      "instance_type": "basic",
      "max_instances": 5,
    },
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "released-db",
      "database_id": "73be1562-d900-4e25-a62b-650ab74488b7",
    },
  ],
  // Cloudflare Flagship feature flags. Prod and staging each have their own
  // app; absence in local dev is safe — flag() falls back to the wrangler var.
  "flagship": [{ "binding": "FLAGS", "app_id": "2cf02390-e39a-477a-91c1-571d07b987ef" }],
  // KV namespace shared with the API worker. Used for:
  //   - Kill switch: "ma:sessions:disabled" blocks all new MA session creation
  //     without a code deploy (wrangler kv:key put --binding=LATEST_CACHE).
  //   - Per-source dedup lock: "ma:active:src:{sourceId}" (15-min TTL)
  //     prevents the same source from spawning two concurrent MA sessions.
  "kv_namespaces": [
    {
      "binding": "LATEST_CACHE",
      "id": "178c70f9abd940478d5b5a053bf123bb",
      "preview_id": "832712867aff4c91bc11bb3cecd7da9e",
    },
  ],
  "services": [{ "binding": "API_WORKER", "service": "releases-api" }],
  "durable_objects": {
    "bindings": [
      { "class_name": "Sandbox", "name": "Sandbox" },
      { "class_name": "ManagedAgentsSession", "name": "MANAGED_AGENTS_SESSION" },
      // Cross-script: the api worker's SourceActor DO owns the per-source
      // MA-delegation lock that replaced the KV ma:active:src:* mutex (#1814).
      { "class_name": "SourceActor", "name": "SOURCE_ACTOR", "script_name": "releases-api" },
    ],
  },
  "migrations": [
    { "new_sqlite_classes": ["Sandbox"], "tag": "v1" },
    { "new_classes": ["DiscoverySession"], "tag": "v2" },
    { "new_classes": ["ManagedAgentsSession"], "tag": "v3" },
    { "deleted_classes": ["DiscoverySession"], "tag": "v4" },
  ],
  "secrets_store_secrets": [
    {
      "binding": "RELEASED_API_KEY",
      "store_id": "a887a71cab084105b79706df23380723",
      "secret_name": "RELEASED_API_KEY",
    },
    {
      "binding": "RELEASES_API_KEY",
      "store_id": "a887a71cab084105b79706df23380723",
      "secret_name": "RELEASES_API_KEY",
    },
    {
      "binding": "ANTHROPIC_API_KEY",
      "store_id": "a887a71cab084105b79706df23380723",
      "secret_name": "ANTHROPIC_API_KEY",
    },
    {
      "binding": "CLOUDFLARE_ACCOUNT_ID",
      "store_id": "a887a71cab084105b79706df23380723",
      "secret_name": "CLOUDFLARE_ACCOUNT_ID",
    },
    {
      "binding": "CLOUDFLARE_API_TOKEN",
      "store_id": "a887a71cab084105b79706df23380723",
      "secret_name": "CLOUDFLARE_API_TOKEN",
    },
    {
      "binding": "AI_GATEWAY_TOKEN",
      "store_id": "a887a71cab084105b79706df23380723",
      "secret_name": "AI_GATEWAY_TOKEN",
    },
    // OpenRouter extraction lane (#1536). Inert until `openrouter-enabled` is on
    // AND EXTRACT_MODEL is set — switch-off (default) keeps extraction on Anthropic.
    {
      "binding": "OPENROUTER_API_KEY",
      "store_id": "a887a71cab084105b79706df23380723",
      "secret_name": "OPENROUTER_API_KEY",
    },
    {
      "binding": "WEB_BOT_AUTH_PRIVATE_KEY",
      "store_id": "a887a71cab084105b79706df23380723",
      "secret_name": "WEB_BOT_AUTH_PRIVATE_KEY",
    },
  ],
  // ── Staging environment ──────────────────────────────────────────────
  // Deployed as `releases-discovery-staging`, service-bound from
  // `releases-api-staging`. Uses a separate Anthropic agent + environment +
  // vault so prompt/skill changes can be iterated without touching prod. Skills
  // are deployed as dedicated staging copies (display title suffixed
  // "(staging)") — see scripts/sync-agent-skills.ts --env staging. Binds
  // STAGING_ACCESS_KEY so outbound calls to api-staging pass the access gate.
  "env": {
    "staging": {
      "name": "releases-discovery-staging",
      "vars": {
        "RELEASES_API_URL": "https://api-staging.releases.sh",
        "ANTHROPIC_AGENT_ID": "agent_011CaHHrroDymm1aEitzUmz1",
        "ANTHROPIC_ENVIRONMENT_ID": "env_015c9WRKAWFfSqAV6tsAj6Qf",
        "ANTHROPIC_VAULT_ID": "vlt_011CaHHvBA7pA6GDwRHJa4TN",
        "ANTHROPIC_WORKER_AGENT_ID": "agent_011CaHHqcTEy9WDeLPzqsmHP",
        "ANTHROPIC_COORDINATOR_AGENT_ID": "agent_011CamrB7cJDfoMufEUd8pTD",
        "MEMORY_STORE_ERRATA_ID": "memstore_01BWRxdBdkPbBWcxmKoVGEA9",
        "MEMORY_STORE_TOOL_NOTES_ID": "memstore_01WQCrdDEjNKGfURRswhWBkb",
        // Route Anthropic SDK calls through Cloudflare AI Gateway.
        // See docs/architecture/ai-gateway.md. Flip on prod after staging burn-in.
        "ANTHROPIC_BASE_URL": "https://gateway.ai.cloudflare.com/v1/b082600d280d44fd5da3501bc1bffe2f/releases-staging/anthropic",
        "WEB_BOT_AUTH_ENABLED": "false",
        "RAW_SNAPSHOT_CAPTURE_ENABLED": "false",
        // OpenRouter extraction lane (issue #1536). Empty → stays on Anthropic
        // (OPENROUTER_API_KEY is bound below; flag + non-empty var still required).
        "EXTRACT_MODEL": "deepseek/deepseek-v4-pro",
      },
      "containers": [
        {
          "class_name": "Sandbox",
          "image": "./Dockerfile",
          "image_build_context": "../../",
          "instance_type": "basic",
          "max_instances": 2,
        },
      ],
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "released-db-staging",
          "database_id": "68d44939-feab-4fcb-8f4f-19778ca1dee8",
        },
      ],
      // Flagship staging app (separate from prod so flag states are isolated).
      "flagship": [{ "binding": "FLAGS", "app_id": "548a95f1-4f8c-402d-8aa2-1b861523d377" }],
      // KV reuses the staging preview namespace — same IDs as api-staging.
      // Keeps kill-switch + dedup-lock testing self-contained in staging.
      "kv_namespaces": [{ "binding": "LATEST_CACHE", "id": "832712867aff4c91bc11bb3cecd7da9e" }],
      "services": [{ "binding": "API_WORKER", "service": "releases-api-staging" }],
      "durable_objects": {
        "bindings": [
          { "class_name": "Sandbox", "name": "Sandbox" },
          { "class_name": "ManagedAgentsSession", "name": "MANAGED_AGENTS_SESSION" },
          // Cross-script: staging SourceActor lock (#1814).
          {
            "class_name": "SourceActor",
            "name": "SOURCE_ACTOR",
            "script_name": "releases-api-staging",
          },
        ],
      },
      // Fresh worker — collapse prod's v1-v4 into a single create step.
      "migrations": [
        { "new_sqlite_classes": ["Sandbox"], "tag": "v1" },
        { "new_classes": ["ManagedAgentsSession"], "tag": "v2" },
      ],
      "secrets_store_secrets": [
        {
          "binding": "RELEASED_API_KEY",
          "store_id": "a887a71cab084105b79706df23380723",
          "secret_name": "RELEASED_API_KEY",
        },
        {
          "binding": "RELEASES_API_KEY",
          "store_id": "a887a71cab084105b79706df23380723",
          "secret_name": "RELEASES_API_KEY",
        },
        {
          "binding": "ANTHROPIC_API_KEY",
          "store_id": "a887a71cab084105b79706df23380723",
          "secret_name": "ANTHROPIC_API_KEY",
        },
        {
          "binding": "CLOUDFLARE_ACCOUNT_ID",
          "store_id": "a887a71cab084105b79706df23380723",
          "secret_name": "CLOUDFLARE_ACCOUNT_ID",
        },
        {
          "binding": "CLOUDFLARE_API_TOKEN",
          "store_id": "a887a71cab084105b79706df23380723",
          "secret_name": "CLOUDFLARE_API_TOKEN",
        },
        {
          "binding": "STAGING_ACCESS_KEY",
          "store_id": "a887a71cab084105b79706df23380723",
          "secret_name": "STAGING_ACCESS_KEY",
        },
        {
          "binding": "AI_GATEWAY_TOKEN",
          "store_id": "a887a71cab084105b79706df23380723",
          "secret_name": "AI_GATEWAY_TOKEN_STAGING",
        },
        // OpenRouter extraction lane (#1536). Unsuffixed secret_name (same store
        // entry the API worker's staging block reuses) — no staging-specific key.
        {
          "binding": "OPENROUTER_API_KEY",
          "store_id": "a887a71cab084105b79706df23380723",
          "secret_name": "OPENROUTER_API_KEY",
        },
        {
          "binding": "WEB_BOT_AUTH_PRIVATE_KEY",
          "store_id": "a887a71cab084105b79706df23380723",
          "secret_name": "WEB_BOT_AUTH_PRIVATE_KEY",
        },
      ],
    },
  },
}
