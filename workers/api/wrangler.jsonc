{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "releases-api",
  "main": "src/index.ts",
  "alias": {
    "bun:sqlite": "./src/stubs/bun-sqlite.ts",
  },
  "compatibility_date": "2026-03-27",
  "compatibility_flags": ["nodejs_compat"],
  // Workers Cache (GA, requires wrangler 4.69+): a per-Worker tiered cache in
  // front of fetch(), driven by the Cache-Control headers routes already set
  // (middleware/cache.ts). Cache hits never run the Worker. Replaces the old
  // hand-rolled caches.default edge-cache middleware (#1800 origin, retired
  // here). The [env.staging] block below explicitly disables this — staging
  // sits behind the STAGING_ACCESS_KEY gate and caching a gated response would
  // make the gate's enforcement invisible to debugging (a cached 200 would
  // outlive a key rotation) and complicate the read-surface iteration staging
  // exists for. See docs/architecture and .context/2026-07-07-workers-cache-migration.md.
  "cache": { "enabled": true },
  "observability": {
    "enabled": true,
    "logs": {
      "enabled": true,
      "destinations": ["axiom-logs"],
    },
    "traces": {
      "enabled": true,
      "destinations": ["axiom-traces"],
    },
  },
  "vars": {
    "CRON_ENABLED": "true",
    "FORCE_DRAIN_STALE_HOURS": "72",
    "MEDIA_ORIGIN": "https://media.releases.sh",
    // Embedding provider for semantic search. Default: voyage (voyage-4-lite,
    // requested at 512 dims via output_dimension to match the Vectorize indexes).
    // Switch to "openai" or "workers-ai" requires updating the matching secret.
    "EMBEDDING_PROVIDER": "voyage",
    // Kill-switch for the PUBLIC_RATE_LIMITER binding below. Tune the cap there.
    "RATE_LIMIT_ENABLED": "false",
    // Kill-switch for the per-token TOKEN_RATE_LIMITER binding. Tune the cap there.
    "TOKEN_RATE_LIMIT_ENABLED": "true",
    // Kill-switch for the edge per-IP AUTH_RATE_LIMITER in front of POST
    // /api/auth/* (#1728). On by default; set to "false" to bypass. Tune the cap
    // on the binding below. See the /api/auth/* handler in src/index.ts.
    "AUTH_EDGE_RATE_LIMIT_ENABLED": "true",
    // Kill-switch for the anonymous self-serve listing lane (/v1/listing
    // validate + activate, #1947 phase 2). Off = both routes refuse.
    "LISTING_SELF_SERVE_ENABLED": "true",
    // Kill-switch for self-serve Tier-1 promotion by verified owners
    // (/v1/listing/promote, #1947 PR B). Off = route refuses. Distinct from
    // LISTING_SELF_SERVE_ENABLED because promotion creates live fetching
    // sources (real spend); off by default until the flow has been validated.
    "LISTING_SELF_SERVE_PROMOTION_ENABLED": "false",
    // Email notifications (see src/lib/email.ts + src/lib/notifications.ts).
    // Recipient must be verified in Cloudflare Email Routing; sender domain
    // (releases.sh) must have Email Routing enabled.
    "EMAIL_NOTIFY_ENABLED": "true",
    "EMAIL_NOTIFY_TO": "admin@releases.sh",
    "EMAIL_FROM": "notifications@releases.sh",
    // Sender for user-facing auth email (AUTH_EMAIL binding; see src/auth/email.ts).
    "AUTH_EMAIL_FROM": "noreply@releases.sh",
    "AUTH_EMAIL_FROM_NAME": "Releases",
    // Digest email sender (AUTH_EMAIL binding). Must be in allowed_sender_addresses.
    "DIGEST_EMAIL_FROM": "digests@releases.sh",
    // Digest cron tunables. Max recipients processed per cron fire; max releases
    // shown per email; how far back a post may have been published and still be
    // mailed (bounds a backfill's blast radius — the delivery window itself is on
    // fetched_at). Safe defaults are baked into send-digests.ts when absent.
    "DIGEST_MAX_PER_RUN": "500",
    "DIGEST_MAX_RELEASES": "50",
    "DIGEST_PUBLISHED_FLOOR_DAYS": "30",
    // API worker public origin — used to build unsubscribe URLs in digest emails.
    "API_BASE_URL": "https://api.releases.sh",
    // Kill switch for the open POST /v1/feedback endpoint (releases feedback).
    "FEEDBACK_DISABLED": "false",
    // Per-IP rate limiter for /v1/feedback (binding FEEDBACK_RATE_LIMITER). On
    // by default; set to "false" to bypass. See routes/feedback.ts.
    "FEEDBACK_RATE_LIMIT_ENABLED": "true",
    // Per-sub (5/min) + per-user (20/min) caps on POST /v1/me/webhooks/:id/test.
    // On by default; set to "false" to bypass. See webhooks/test-rate-limit.ts.
    "WEBHOOK_TEST_RATE_LIMIT_ENABLED": "true",
    // Max feedback notification emails per rolling hour (inbox-bomb cap).
    "FEEDBACK_NOTIFY_MAX_PER_HOUR": "20",
    "ADMIN_BASE_URL": "https://api.releases.sh",
    // Event-driven KV purge of GET /v1/releases/latest. Ships "false" to
    // run the helper in shadow mode (log-only); flip to "true" after a
    // week of parity-check logs. See #408.
    "INVALIDATION_ENABLED": "false",
    // Managed-agents errata memory store — destination for POST /v1/errata/:orgId
    // writes. Discovery worker binds tool-notes separately; the API worker only
    // touches errata. See #537.
    "MEMORY_STORE_ERRATA_ID": "memstore_012MKStcUM7QxW9qPCLQtwwt",
    // Retention window for `search_queries` rows. Rows older than this many days
    // are deleted by the nightly 05:00 UTC sweep (see issue #575). Default 90.
    "SEARCH_QUERY_RETENTION_DAYS": "90",
    // ANTHROPIC_BASE_URL routes Anthropic SDK calls through Cloudflare AI
    // Gateway. It embeds an account-scoped gateway URL, so it is provisioned as
    // a worker secret (`wrangler secret put ANTHROPIC_BASE_URL`), not a var —
    // forks and self-hosters get the direct-Anthropic default (unset → no
    // gateway, fail-open). See docs/architecture/ai-gateway.md. Gateway runs in
    // authenticated mode — the AI_GATEWAY_TOKEN secret below must be bound.
    // OpenRouter cheap-call model for the marketing classifier. Consulted only
    // when the `openrouter-enabled` flag is on; otherwise the classifier stays on
    // Anthropic Haiku. OpenRouter is called directly (not fronted by the CF AI
    // Gateway — no double-hop, per docs/architecture/ai-gateway.md Layer 1).
    "MARKETING_CLASSIFIER_MODEL": "google/gemini-2.5-flash-lite",
    // OpenRouter cheap-call model for the *live* poll-fetch summarizer AND the
    // nightly collection-daily-summary cron (both consume SUMMARIZE_MODEL).
    // Consulted only when `openrouter-enabled` is on; empty → both stay on
    // Anthropic Haiku (fail-open). The daily release batch path is unaffected
    // (always Anthropic).
    //
    // deepseek-v4-flash after the #1633 bench (`bun run eval:summary` +
    // `eval:collection-summary -- --judge`, judge=gemini-2.5-flash): on
    // collection summaries it clearly beats gemini-2.5-flash-lite (3/4 vs 1/4
    // satisfied — tighter, version-free, honest quiet-day summaries); on
    // release-content it is at parity (11 vs 12 of 16, within judge noise) with
    // zero starvation at the 280-token cap — at lower per-call cost than
    // gemini-flash-lite. DeepSeek V4 is a reasoning model; the summarize lanes
    // disable reasoning via the OpenRouter transport (resolveSummarizeModel /
    // resolveCollectionSummaryModel set reasoning:{enabled:false}) so the small
    // token budget is not spent thinking, and exclude the GMICloud provider whose
    // DeepSeek latency is an outlier. (Prior baseline: gemini-2.5-flash-lite, set
    // per the #1469 release-content eval.)
    "SUMMARIZE_MODEL": "deepseek/deepseek-v4-flash",
    // OpenRouter model for the large-body EXTRACTION tool-loop (issue #1536).
    // Consulted only when `openrouter-enabled` is on; empty → extraction stays on
    // Anthropic (fail-open). OPENROUTER_API_KEY is already bound below.
    // Set to deepseek-v4-pro after the extraction eval showed corpus-wide parity
    // with Sonnet-4.6 (issue #1536); reasoning is disabled in the OpenRouter model.
    "EXTRACT_MODEL": "deepseek/deepseek-v4-pro",
    // OpenRouter model for the feed-enrichment single-article extractor. Consulted
    // only when `openrouter-enabled` is on; empty → enrichment stays on Anthropic
    // Haiku (fail-open). Set to deepseek-v4-flash after the article-extract eval
    // (`bun run eval:article-extract`) showed deterministic 5/5 parity with Haiku on
    // body fidelity + other-article exclusion at ~85% lower per-call cost. Reasoning
    // stays at the model default (ON) here — unlike the #1536 tool-loop it improves
    // shell-page detection and does not truncate (verified on a long-changelog
    // fixture). The async Message-Batches enrichment path is unaffected (always
    // Anthropic; OpenRouter has no Batches API).
    "FEED_ENRICH_MODEL": "deepseek/deepseek-v4-flash",
    // Smear window for the per-source jitter at the head of PollAndFetchWorkflow.
    // Set to "0" to disable; see FANOUT_JITTER_WINDOW_MAX_MS for the upper clamp.
    // See workers/api/src/workflows/poll-and-fetch.ts.
    "FANOUT_JITTER_WINDOW_MS": "300000",
    // Batch summarization workflow (issue #971). Enabled — daily 04:30 UTC cron
    // walks the past 24h of releases across orgs with auto_generate_content=true
    // (~26 orgs as of enable). Admin POST trigger
    // (POST /v1/workflows/batch-summarize) runs unconditionally regardless of
    // this flag.
    "BATCH_SUMMARIZE_ENABLED": "true",
    // Per-run cost ceiling in USD. Pre-submission cost estimate (from body
    // token counts + batch discount) must stay under this value or the workflow
    // aborts with NonRetryableError before submitting anything to Anthropic.
    "BATCH_SUMMARIZE_MAX_COST_USD": "10",
    // OpenRouter-backed per-org overview regen. Admin POST trigger only for now;
    // cron path self-gates on this var (default off).
    "OVERVIEW_REGEN_ENABLED": "false",
    // Velocity fast tier (#1895): orgs shipping >= OVERVIEW_FAST_MIN_RELEASES
    // since their last overview requalify after OVERVIEW_FAST_CADENCE_DAYS
    // instead of the 7-day default. Per-org overview_cadence_days overrides
    // beat both tiers. Unset/invalid falls back to the in-code defaults.
    "OVERVIEW_FAST_CADENCE_DAYS": "2",
    "OVERVIEW_FAST_MIN_RELEASES": "15",
    // Batch feed-content enrichment backfill (#1296). Admin POST trigger only
    // (POST /v1/workflows/batch-enrich) runs unconditionally; BATCH_ENRICH_ENABLED
    // is reserved for a future cron path. The pre-fetch cost estimate (bounded by
    // the per-item input cap × batch discount) must stay under the ceiling or the
    // workflow aborts before submitting.
    "BATCH_ENRICH_ENABLED": "false",
    "BATCH_ENRICH_MAX_COST_USD": "10",
    // Public web origin used to build canonical URLs for IndexNow pings (#649).
    "WEB_BASE_URL": "https://releases.sh",
    // Better Auth public base URL — THIS worker (where /api/auth/* is served),
    // not the web origin. Drives OAuth callback + cross-subdomain cookie domain
    // (.releases.sh). Local dev sets https://api.releases.localhost via .dev.vars.
    "BETTER_AUTH_URL": "https://api.releases.sh",
    // Project-scoped Better Auth Infrastructure KV "identify" endpoint for the
    // sentinel() security plugin. A project URL, not a secret (the credential is
    // BETTER_AUTH_API_KEY in Secrets Store); sentinel() mounts only when both
    // resolve. See src/auth/index.ts.
    "BETTER_AUTH_IDENTIFY_URL": "https://kv.better-auth.com/projects/U2pO0qgccJ5s4wxCtzTpOlgKvH3Q0V1Z",
    // Feed content enrichment (#feed-enrich). When a feed item arrives
    // summary-only, follow its link and capture the full article via cheap
    // fetch → AI extract, escalating to Cloudflare Browser Rendering only when
    // the result is still thin. Enabled in prod after staging validation
    // (#1109 follow-up). The forward path is cron-gated (poll-fetch); the admin
    // backfill POST /v1/workflows/enrich-feed-content runs regardless.
    // FEED_ENRICH_MAX_PER_FIRE caps enrich attempts per source per cron fire;
    // FEED_THIN_CHARS is the char floor below which a body counts as "thin".
    "FEED_ENRICH_ENABLED": "true",
    "FEED_ENRICH_MAX_PER_FIRE": "10",
    "FEED_THIN_CHARS": "600",
    // Routes deep Firecrawl backfills to BackfillSourceWorkflow (#1281). Default
    // off → POST /v1/workflows/backfill-source stays fully synchronous. Flip to
    // "true" (or the Flagship key backfill-workflow-enabled) once released-raw
    // exists and BackfillSourceWorkflow is bound.
    "BACKFILL_WORKFLOW_ENABLED": "false",
    // Discriminator read by /v1/graphql to gate GraphiQL + introspection.
    // Production deploys advertise "production"; the staging block overrides
    // to "staging".
    "ENVIRONMENT": "production",
    "WEB_BOT_AUTH_ENABLED": "true",
    "USER_API_KEYS_ENABLED": "false",
    "WELL_KNOWN_MATERIALIZATION_ENABLED": "true",
    // Comma-separated audience URIs accepted in JWT access tokens issued by the
    // OAuth provider. The API worker origin (BETTER_AUTH_URL) is always included;
    // this var adds remote resource servers (first consumer: the MCP worker).
    // See src/auth/index.ts `oauthValidAudiences()`.
    "OAUTH_RESOURCE_AUDIENCES": "https://mcp.releases.sh",
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "released-db",
      "database_id": "73be1562-d900-4e25-a62b-650ab74488b7",
    },
  ],
  // Cloudflare Flagship feature flags. Prod and staging each have their own
  // app; absence in local dev is safe — flag() falls back to the wrangler var.
  "flagship": [{ "binding": "FLAGS", "app_id": "2cf02390-e39a-477a-91c1-571d07b987ef" }],
  // Vectorize indexes for semantic search. Provision once via
  // scripts/create-vectorize-indexes.sh before first deploy.
  "vectorize": [
    { "binding": "RELEASES_INDEX", "index_name": "releases-v1" },
    { "binding": "ENTITIES_INDEX", "index_name": "entities-v1" },
    { "binding": "CHANGELOG_CHUNKS_INDEX", "index_name": "changelog-chunks-v1" },
  ],
  // KV namespaces. LATEST_CACHE fronts GET /v1/releases/latest with a
  // 300s TTL (keys: latest:v2:<sorted-qs>). Optional — `withLatestCache`
  // degrades to pass-through when the binding is absent.
  // ALERT_DEDUP_KV stores 1h dedup keys for Tier-1 alert emails (keys:
  // alert:<subject>). Reuses the LATEST_CACHE namespace to avoid provisioning
  // a new resource — alert keys use a distinct prefix so they never collide.
  "kv_namespaces": [
    {
      "binding": "EMBED_CACHE",
      "id": "93b87ae5e253445cabbaaa7a71264915",
      "preview_id": "7737ccafd37a43fc9d2365c9a2d7ebca",
    },
    {
      "binding": "LATEST_CACHE",
      "id": "178c70f9abd940478d5b5a053bf123bb",
      "preview_id": "832712867aff4c91bc11bb3cecd7da9e",
    },
    {
      "binding": "ALERT_DEDUP_KV",
      "id": "178c70f9abd940478d5b5a053bf123bb",
      "preview_id": "832712867aff4c91bc11bb3cecd7da9e",
    },
    // Caches credential-validation results for the account rate-limit tier
    // (hash(credential) → {valid,userId}, ~60s TTL; never counters). Optional in
    // code — an absent binding degrades to per-request verify. Bound only on the
    // API worker (the sole consumer); the MCP worker resolves identity before
    // enforcement and does not bind it. What's shared across workers is the
    // @releases/lib/rate-limit-tiers helper, NOT this binding. See middleware/rate-limit.ts.
    {
      "binding": "CREDENTIAL_CACHE",
      "id": "bae0fa6a594448d483176fe90a9a0479",
      "preview_id": "ac4b692c975a4d9382a847e968243107",
    },
    // Backs Better Auth's brute-force rate-limit counters (per-key IP+path) so
    // those upserts land on KV instead of the shared D1 (#1728). createAuth wires
    // it via rateLimit.customStorage when bound; absent → storage:"database".
    // Counters only ever live ~120s (AUTH_RATE_LIMIT_KV_TTL_SECONDS). See
    // src/auth/rate-limit-kv.ts.
    {
      "binding": "AUTH_RATE_LIMIT_KV",
      "id": "1d1c229b6a71483ab9517bf316e4a7b4",
      "preview_id": "e972050279ba425eb6a9cbd78ad7539e",
    },
  ],
  "services": [
    {
      "binding": "DISCOVERY_WORKER",
      "service": "releases-discovery",
      "entrypoint": "DiscoveryEntrypoint",
    },
    {
      // Self binding (#1946): the deterministic-update workflow's scrapeFetch
      // persists via this worker's own HTTP routes; the self hop preserves the
      // per-call invocation semantics of the retired discovery->api boundary.
      "binding": "API_SELF",
      "service": "releases-api",
    },
  ],
  "r2_buckets": [
    {
      "binding": "MEDIA",
      "bucket_name": "released-media",
    },
    {
      // Raw page snapshots for durable backfill (#1281). One-time prereq before
      // deploy: `wrangler r2 bucket create released-raw` + a 90-day lifecycle
      // (expire) rule — raw is ephemeral/audit, unlike permanent public media.
      "binding": "RAW_SNAPSHOTS",
      "bucket_name": "released-raw",
    },
  ],
  // Cloudflare Media Transformations binding for ingest-time GIF→MP4 (#1368).
  // Distinct NAME from the R2 bucket `MEDIA` above (env.MEDIA = bucket;
  // env.MEDIA_TRANSFORM = transformer). Public-beta binding; unbilled now.
  "media": { "binding": "MEDIA_TRANSFORM" },
  "queues": {
    "producers": [
      { "binding": "WEBHOOK_DELIVERY_QUEUE", "queue": "webhook-delivery" },
      { "binding": "DIGEST_DELIVERY_QUEUE", "queue": "digest-delivery" },
      { "binding": "RELEASE_EVENTS_QUEUE", "queue": "release-events" },
    ],
    "consumers": [
      {
        "queue": "digest-delivery",
        "max_batch_size": 10,
        "max_batch_timeout": 5,
        "max_retries": 5,
      },
      {
        "queue": "release-events",
        "max_batch_size": 5,
        "max_batch_timeout": 5,
        "max_retries": 5,
      },
    ],
  },
  // Two Email bindings. SEND_EMAIL = Email Routing (internal ops notifications,
  // reaches only account-verified destinations). AUTH_EMAIL = Email Sending
  // (user-facing verification + password-reset mail to arbitrary recipients),
  // sender-locked to noreply@releases.sh and digests@releases.sh. Requires
  // Email Sending enabled on the account + releases.sh verified for Email
  // Sending (DKIM) — see the spec.
  "send_email": [
    { "name": "SEND_EMAIL" },
    {
      "name": "AUTH_EMAIL",
      "allowed_sender_addresses": ["noreply@releases.sh", "digests@releases.sh"],
    },
  ],
  "durable_objects": {
    "bindings": [
      { "class_name": "StatusHub", "name": "STATUS_HUB" },
      { "class_name": "ReleaseHub", "name": "RELEASE_HUB" },
      { "class_name": "SourceActor", "name": "SOURCE_ACTOR" },
      { "class_name": "OrgActor", "name": "ORG_ACTOR" },
    ],
  },
  "migrations": [
    { "new_classes": ["StatusHub"], "tag": "v1" },
    { "new_classes": ["ReleaseHub"], "tag": "v2" },
    { "new_classes": ["SourceActor"], "tag": "v3" },
    { "new_classes": ["OrgActor"], "tag": "v4" },
  ],
  // Cloudflare Workflows — durable, retriable multi-step pipelines. See
  // workers/api/src/workflows/. Prod-only; staging doesn't
  // run crons (see memory: feedback_staging_no_crons.md).
  "workflows": [
    {
      "name": "poll-and-fetch",
      "binding": "POLL_AND_FETCH_WORKFLOW",
      "class_name": "PollAndFetchWorkflow",
    },
    {
      // One instance per `POST /v1/sources` create (when this binding is wired).
      // Walks playbook → embed → backfill-fetch with per-step retries. See #493.
      "name": "onboard-source",
      "binding": "ONBOARD_SOURCE_WORKFLOW",
      "class_name": "OnboardSourceWorkflow",
    },
    {
      // Daily batch summarization. Cron fires daily at 04:30 UTC; self-gates via
      // BATCH_SUMMARIZE_ENABLED. Admin POST trigger runs unconditionally. See #971.
      "name": "batch-summarize",
      "binding": "BATCH_SUMMARIZE_WORKFLOW",
      "class_name": "BatchSummarizeWorkflow",
    },
    {
      // Triggered by inbound Firecrawl webhook (POST /v1/integrations/firecrawl/webhook)
      // when a monitored source page has changed. Scrapes via Firecrawl, extracts,
      // inserts, embeds, and optionally summarizes. Phase 2 of the Firecrawl
      // monitoring integration.
      "name": "firecrawl-ingest",
      "binding": "FIRECRAWL_INGEST_WORKFLOW",
      "class_name": "FirecrawlIngestWorkflow",
    },
    {
      // Full-history backfill for windowed scrape sources (#1281). Saves raw body
      // to R2 once, then extracts each window as its own resumable step. Triggered
      // by POST /v1/workflows/backfill-source when BACKFILL_WORKFLOW_ENABLED=true.
      "name": "backfill-source",
      "binding": "BACKFILL_SOURCE_WORKFLOW",
      "class_name": "BackfillSourceWorkflow",
    },
    {
      // Batched feed-content enrichment backfill (#1296). Per-item Browser-
      // Rendering fetch (→ R2) then ONE Anthropic Message Batch for extraction.
      // Admin POST trigger only (POST /v1/workflows/batch-enrich); drains the
      // render-heavy / JS-shell summary-only sources the sync route can't finish.
      "name": "batch-enrich",
      "binding": "BATCH_ENRICH_WORKFLOW",
      "class_name": "BatchEnrichWorkflow",
    },
    {
      // OpenRouter-backed per-org overview regeneration. Cron path self-gates
      // via OVERVIEW_REGEN_ENABLED (default off); admin POST runs unconditionally
      // (POST /v1/workflows/overview-regen).
      "name": "overview-regen",
      "binding": "OVERVIEW_REGEN_WORKFLOW",
      "class_name": "OverviewRegenWorkflow",
    },
    {
      // Collection daily summaries. Cron at 06:15 UTC; admin POST
      // (POST /v1/workflows/collection-summaries).
      "name": "collection-summaries",
      "binding": "COLLECTION_SUMMARIES_WORKFLOW",
      "class_name": "CollectionSummariesWorkflow",
    },
    {
      // Durable media / video / gif backfill loops (POST /v1/workflows/backfill-*).
      "name": "media-backfill",
      "binding": "MEDIA_BACKFILL_WORKFLOW",
      "class_name": "MediaBackfillWorkflow",
    },
    {
      // Deterministic scrape/agent update runs (#1946): one instance per
      // OrgActor drain / POST /v1/workflows/update / crawl-feed delegation.
      // Replaced the discovery worker's /update session path.
      "name": "deterministic-update",
      "binding": "DETERMINISTIC_UPDATE_WORKFLOW",
      "class_name": "DeterministicUpdateWorkflow",
    },
  ],
  "routes": [{ "pattern": "api.releases.sh", "custom_domain": true }],
  "triggers": {
    // Hourly: poll feed sources and fetch changed ones.
    // Daily at 03:00 UTC: recompute fetchPriority tiers based on cadence.
    // Daily at 04:00 UTC: send the source staleness digest.
    // Daily at 04:30 UTC: batch summarization (self-gates via BATCH_SUMMARIZE_ENABLED). See #971.
    // Daily at 05:00 UTC: delete search_queries rows older than SEARCH_QUERY_RETENTION_DAYS (#575).
    // Daily at 05:30 UTC: hard-purge tombstoned orgs/sources/products older than TOMBSTONE_RETENTION_DAYS (#666).
    // Daily at 06:00 UTC: well-known config sync sweep.
    // Daily at 06:30 UTC: mobile-app discovery sweep (AASA + assetlinks.json → paused appstore candidates).
    // Daily at 06:15 UTC: generate collection daily summaries.
    // Daily at 07:00 UTC: reap stale dynamic-registration OAuth clients (observe-only until oauth-client-reaper-enabled).
    // Daily at 08:00 UTC: org overview regeneration (self-gates via overviewRegenEnabled;
    //   per-org cadence — 7d default, 2d fast tier, overview_cadence_days override — gates who regenerates, #1895).
    // Daily at 13:00 UTC: send daily digests to subscribed users (#1518).
    // Mondays at 13:00 UTC: send weekly digests to subscribed users (#1518, "MON" per #1796).
    "crons": [
      "0 * * * *",
      "0 3 * * *",
      "0 4 * * *",
      "30 4 * * *",
      "0 5 * * *",
      "30 5 * * *",
      "0 6 * * *",
      "30 6 * * *",
      "15 6 * * *",
      "0 7 * * *",
      "0 8 * * *", // 08:00 UTC daily: overview regeneration (OpenRouter; per-org cadence gates, #1895)
      "0 13 * * *",
      "0 13 * * MON", // named weekday: Cloudflare cron numbers weekdays 1=Sunday..7=Saturday (#1796)
    ],
  },
  // State is per-colo, not global. `period` must be 10 or 60 (CF constraint).
  "unsafe": {
    "bindings": [
      {
        "name": "PUBLIC_RATE_LIMITER",
        "type": "ratelimit",
        "namespace_id": "1001",
        "simple": { "limit": 120, "period": 60 },
      },
      // Per-token cap for relk_ tokens (root + trusted proxy are exempt).
      // Keyed by tokenId; gated by TOKEN_RATE_LIMIT_ENABLED (default off).
      {
        "name": "TOKEN_RATE_LIMITER",
        "type": "ratelimit",
        "namespace_id": "1002",
        "simple": { "limit": 600, "period": 60 },
      },
      // Per-IP cap for the open POST /v1/feedback. Enforced in-handler
      // (routes/feedback.ts), gated by FEEDBACK_RATE_LIMIT_ENABLED (default on).
      {
        "name": "FEEDBACK_RATE_LIMITER",
        "type": "ratelimit",
        "namespace_id": "1003",
        "simple": { "limit": 5, "period": 60 },
      },
      // Self-serve webhook synthetic test sends (routes/me-webhooks.ts).
      {
        "name": "WEBHOOK_TEST_SUB_RATE_LIMITER",
        "type": "ratelimit",
        "namespace_id": "1004",
        "simple": { "limit": 5, "period": 60 },
      },
      {
        "name": "WEBHOOK_TEST_USER_RATE_LIMITER",
        "type": "ratelimit",
        "namespace_id": "1005",
        "simple": { "limit": 20, "period": 60 },
      },
      // Per-account cap for authenticated free accounts (relu_ user keys + OAuth
      // JWT users), keyed by userId. Rides RATE_LIMIT_ENABLED (same gate as the
      // per-IP public limiter). Sits between anonymous (120) and machine (600).
      {
        "name": "USER_RATE_LIMITER",
        "type": "ratelimit",
        "namespace_id": "1006",
        "simple": { "limit": 300, "period": 60 },
      },
      // Per-IP edge gate in FRONT of POST /api/auth/* (#1728). Sheds brute-force /
      // credential-stuffing floods before Better Auth's per-key limiter runs, so
      // the flood never write-amplifies into the shared D1. Enforced in the
      // /api/auth/* handler (src/index.ts), gated by AUTH_EDGE_RATE_LIMIT_ENABLED
      // (default on). 30/60s/IP is generous vs the built-in 3-per-10s sign-in
      // ceiling (~18/min) so legit users (incl. shared-NAT offices) clear it.
      {
        "name": "AUTH_RATE_LIMITER",
        "type": "ratelimit",
        "namespace_id": "1007",
        "simple": { "limit": 30, "period": 60 },
      },
      {
        // Self-serve listing lane (#1947 phase 2): per-IP across validate+activate.
        "name": "LISTING_RATE_LIMITER",
        "type": "ratelimit",
        "namespace_id": "1008",
        "simple": { "limit": 10, "period": 60 },
      },
      {
        // Per-domain churn brake on activate. CF-native limiters cap at 60s
        // windows; activation is idempotent so a daily KV counter isn't needed.
        "name": "LISTING_DOMAIN_RATE_LIMITER",
        "type": "ratelimit",
        "namespace_id": "1009",
        "simple": { "limit": 3, "period": 60 },
      },
    ],
  },
  // Secrets are managed in Cloudflare's Secrets Store (dashboard → Workers → Secrets Store).
  // To rotate or switch providers, update the secret there and redeploy.
  "secrets_store_secrets": [
    {
      "binding": "RELEASED_API_KEY",
      "store_id": "a887a71cab084105b79706df23380723",
      "secret_name": "RELEASED_API_KEY",
    },
    // New-prefix alias of the static root credential. Dual-bound during the
    // RELEASED_->RELEASES_ migration; legacy binding removed in the teardown.
    {
      "binding": "RELEASES_API_KEY",
      "store_id": "a887a71cab084105b79706df23380723",
      "secret_name": "RELEASES_API_KEY",
    },
    // RELEASES_PROXY_KEY exempts the web frontend's server-to-server traffic
    // from the per-IP public rate limiter without unlocking admin content.
    {
      "binding": "RELEASES_PROXY_KEY",
      "store_id": "a887a71cab084105b79706df23380723",
      "secret_name": "RELEASES_PROXY_KEY",
    },
    {
      "binding": "GITHUB_TOKEN",
      "store_id": "a887a71cab084105b79706df23380723",
      "secret_name": "GITHUB_TOKEN",
    },
    // Better Auth signing secret (human user sessions). Already provisioned in
    // the Secrets Store.
    {
      "binding": "BETTER_AUTH_SECRET",
      "store_id": "a887a71cab084105b79706df23380723",
      "secret_name": "BETTER_AUTH_SECRET",
    },
    // Better Auth Infrastructure ("dash") API key — connects this backend to the
    // hosted dashboard at dash.better-auth.com. The dash() plugin (src/auth/
    // index.ts) is gated on this resolving, so binding it activates the connection.
    {
      "binding": "BETTER_AUTH_API_KEY",
      "store_id": "a887a71cab084105b79706df23380723",
      "secret_name": "BETTER_AUTH_API_KEY",
    },
    // Google social login. Binding both halves of the credential pair activates
    // the provider via `buildSocialProviders` (src/auth/index.ts) AND mounts the
    // Google One Tap plugin — no code change, that's the "social-ready" seam. The
    // OAuth app's redirect URI must be https://api.releases.sh/api/auth/callback/google
    // and its JS origin https://releases.sh (One Tap) before this goes live; the web
    // side reveals the button via NEXT_PUBLIC_AUTH_SOCIAL_PROVIDERS=google. GitHub is
    // NOT bound — its client id/secret aren't in the Secrets Store yet, so binding it
    // here would fail the deploy; it stays gated off in code until those values exist.
    {
      "binding": "GOOGLE_CLIENT_ID",
      "store_id": "a887a71cab084105b79706df23380723",
      "secret_name": "GOOGLE_CLIENT_ID",
    },
    {
      "binding": "GOOGLE_CLIENT_SECRET",
      "store_id": "a887a71cab084105b79706df23380723",
      "secret_name": "GOOGLE_CLIENT_SECRET",
    },
    // Stripe customer registration (`@better-auth/stripe`). STRIPE_SECRET_KEY is the
    // account API key; STRIPE_WEBHOOK_SECRET is the signing secret for the
    // /api/auth/stripe/webhook endpoint (from the Stripe dashboard webhook). Both
    // resolving activates the plugin (buildStripePlugin in src/auth/index.ts) — a
    // Stripe Customer is created on sign-up and linked via user.stripeCustomerId.
    // Bound here for prod (the default env); the [env.staging] block below does NOT
    // inherit these, so staging stays Stripe-less until its own sandbox secrets are
    // provisioned and bound there (the plugin is gated, so the absence is inert).
    {
      "binding": "STRIPE_SECRET_KEY",
      "store_id": "a887a71cab084105b79706df23380723",
      "secret_name": "STRIPE_SECRET_KEY",
    },
    {
      "binding": "STRIPE_WEBHOOK_SECRET",
      "store_id": "a887a71cab084105b79706df23380723",
      "secret_name": "STRIPE_WEBHOOK_SECRET",
    },
    {
      "binding": "VOYAGE_API_KEY",
      "store_id": "a887a71cab084105b79706df23380723",
      "secret_name": "VOYAGER_API_KEY",
    },
    {
      "binding": "ANTHROPIC_API_KEY",
      "store_id": "a887a71cab084105b79706df23380723",
      "secret_name": "ANTHROPIC_API_KEY",
    },
    {
      "binding": "WEBHOOK_HMAC_MASTER",
      "store_id": "a887a71cab084105b79706df23380723",
      "secret_name": "WEBHOOK_HMAC_MASTER",
    },
    {
      "binding": "AI_GATEWAY_TOKEN",
      "store_id": "a887a71cab084105b79706df23380723",
      "secret_name": "AI_GATEWAY_TOKEN",
    },
    // OpenRouter cheap-call lanes. Inert until `openrouter-enabled` is on AND a
    // lane model var (e.g. MARKETING_CLASSIFIER_MODEL) is set — switch-off
    // (default) keeps every lane on Anthropic Haiku.
    {
      "binding": "OPENROUTER_API_KEY",
      "store_id": "a887a71cab084105b79706df23380723",
      "secret_name": "OPENROUTER_API_KEY",
    },
    // Browser-Rendering-capable credentials for feed enrichment's render
    // escalation (#feed-enrich). Reuses the same Secrets Store entries the
    // discovery worker binds — no new secret values. When absent, enrichment
    // degrades to the cheap fetch+extract path (render escalation is skipped).
    {
      "binding": "CLOUDFLARE_ACCOUNT_ID",
      "store_id": "a887a71cab084105b79706df23380723",
      "secret_name": "CLOUDFLARE_ACCOUNT_ID",
    },
    {
      "binding": "CLOUDFLARE_API_TOKEN",
      "store_id": "a887a71cab084105b79706df23380723",
      "secret_name": "CLOUDFLARE_API_TOKEN",
    },
    // IndexNow ownership key. A missing key makes the IndexNow ping a no-op.
    // The same value must also live in Vercel env so web/src/proxy.ts can serve
    // the ownership file at /{key}.txt.
    {
      "binding": "INDEXNOW_KEY",
      "store_id": "a887a71cab084105b79706df23380723",
      "secret_name": "INDEXNOW_KEY",
    },
    {
      "binding": "WEB_BOT_AUTH_PRIVATE_KEY",
      "store_id": "a887a71cab084105b79706df23380723",
      "secret_name": "WEB_BOT_AUTH_PRIVATE_KEY",
    },
    {
      "binding": "FIRECRAWL_API_KEY",
      "store_id": "a887a71cab084105b79706df23380723",
      "secret_name": "FIRECRAWL_API_KEY",
    },
    {
      "binding": "FIRECRAWL_WEBHOOK_SECRET",
      "store_id": "a887a71cab084105b79706df23380723",
      "secret_name": "FIRECRAWL_WEBHOOK_SECRET",
    },
    // GitHub App webhook signing secret — verifies inbound `X-Hub-Signature-256`
    // on POST /v1/integrations/github/webhook (#1698). Prod only; the staging
    // block doesn't inherit these (no inbound webhooks in staging).
    {
      "binding": "RELEASES_GITHUB_WEBHOOK_SECRET",
      "store_id": "a887a71cab084105b79706df23380723",
      "secret_name": "RELEASES_GITHUB_WEBHOOK_SECRET",
    },
  ],
  // ── Staging environment ──────────────────────────────────────────────
  // Deployed as `releases-api-staging` at api-staging.releases.sh. Points
  // at a separate D1 (released-db-staging) refreshed from prod via the
  // sync-staging-db workflow. Vectorize and the discovery service are
  // intentionally omitted — the search path degrades to FTS, and cron is
  // hard-disabled so staging never writes behind prod's back.
  // Interim access gate: `STAGING_ACCESS_KEY` (see middleware/staging-access.ts)
  // rejects any request missing the `X-Releases-Staging-Key` header. CF Access
  // is still the long-term plan — see issue #444.
  "env": {
    "staging": {
      "name": "releases-api-staging",
      "routes": [{ "pattern": "api-staging.releases.sh", "custom_domain": true }],
      // Explicit disable — env blocks do NOT inherit the top-level `cache`
      // config. Kept off deliberately: staging sits behind STAGING_ACCESS_KEY
      // (middleware/staging-access.ts), and Workers Cache would cache
      // responses across access-key rotations / gate changes, undermining the
      // gate as a debugging surface. See the top-level `cache` comment above.
      "cache": { "enabled": false },
      "vars": {
        "CRON_ENABLED": "false",
        "FORCE_DRAIN_STALE_HOURS": "72",
        "MEDIA_ORIGIN": "https://media.releases.sh",
        "EMBEDDING_PROVIDER": "voyage",
        "RATE_LIMIT_ENABLED": "false",
        "TOKEN_RATE_LIMIT_ENABLED": "false",
        // Staging has no `unsafe` block (no ratelimit bindings); the listing
        // routes' limiter calls no-op there. Var kept for parity.
        "LISTING_SELF_SERVE_ENABLED": "true",
        "LISTING_SELF_SERVE_PROMOTION_ENABLED": "false",
        "EMAIL_NOTIFY_ENABLED": "false",
        "EMAIL_NOTIFY_TO": "admin@releases.sh",
        "EMAIL_FROM": "notifications@releases.sh",
        "AUTH_EMAIL_FROM": "noreply@releases.sh",
        "AUTH_EMAIL_FROM_NAME": "Releases",
        // Digest email vars — mirrors prod; crons are disabled in staging so
        // these are only consulted via the admin POST trigger path.
        "DIGEST_EMAIL_FROM": "digests@releases.sh",
        "DIGEST_MAX_PER_RUN": "500",
        "DIGEST_MAX_RELEASES": "50",
        "DIGEST_PUBLISHED_FLOOR_DAYS": "30",
        "API_BASE_URL": "https://api-staging.releases.sh",
        "FEEDBACK_DISABLED": "false",
        // Staging has no FEEDBACK_RATE_LIMITER binding (no `unsafe` block); the
        // handler no-ops the limiter there. Vars kept for parity.
        "FEEDBACK_RATE_LIMIT_ENABLED": "true",
        "WEBHOOK_TEST_RATE_LIMIT_ENABLED": "true",
        "FEEDBACK_NOTIFY_MAX_PER_HOUR": "20",
        "ADMIN_BASE_URL": "https://api-staging.releases.sh",
        "INVALIDATION_ENABLED": "false",
        "MEMORY_STORE_ERRATA_ID": "memstore_01BWRxdBdkPbBWcxmKoVGEA9",
        // Mirrors prod default; not read in staging (CRON_ENABLED=false). See #575.
        "SEARCH_QUERY_RETENTION_DAYS": "90",
        // Staging-only: emit X-Robots-Tag: noindex on every response and
        // serve a deny-all /robots.txt. Belt-and-suspenders against the
        // staging hostname getting crawled while it sits unprotected.
        "INDEXING_DISABLED": "true",
        // ANTHROPIC_BASE_URL (AI Gateway routing) is a per-env worker secret,
        // not a var — see the prod vars block note + docs/architecture/ai-gateway.md.
        // OpenRouter cheap-call model (marketing classifier); gated by the
        // `openrouter-enabled` flag. Mirrors prod.
        "MARKETING_CLASSIFIER_MODEL": "google/gemini-2.5-flash-lite",
        // OpenRouter cheap-call model for the live summarizer + collection daily
        // summaries; gated by the `openrouter-enabled` flag. deepseek-v4-flash per
        // the #1633 bench (reasoning disabled + GMICloud excluded by the summarize
        // lanes); empty → stays on Anthropic Haiku (fail-open). Mirrors prod.
        "SUMMARIZE_MODEL": "deepseek/deepseek-v4-flash",
        // OpenRouter extraction model (issue #1536); gated by `openrouter-enabled`.
        // Empty → stays on Anthropic (fail-open). Mirrors prod.
        "EXTRACT_MODEL": "deepseek/deepseek-v4-pro",
        // OpenRouter feed-enrichment article model; gated by `openrouter-enabled`.
        // deepseek-v4-flash per the article-extract eval. Empty → Anthropic Haiku
        // (fail-open). Mirrors prod.
        "FEED_ENRICH_MODEL": "deepseek/deepseek-v4-flash",
        // Mirrors prod flag; not read in staging (CRON_ENABLED=false). See #971.
        "BATCH_SUMMARIZE_ENABLED": "false",
        "BATCH_SUMMARIZE_MAX_COST_USD": "10",
        // Overview regen workflow — same staging posture: admin POST usable for
        // wiring validation; cron path is irrelevant (CRON_ENABLED=false).
        "OVERVIEW_REGEN_ENABLED": "false",
        // Velocity fast tier (#1895) — mirrors prod; not read in staging.
        "OVERVIEW_FAST_CADENCE_DAYS": "2",
        "OVERVIEW_FAST_MIN_RELEASES": "15",
        // Mirrors prod default; not read in staging (CRON_ENABLED=false means no
        // cron fires, so PollAndFetchWorkflow instances are never dispatched).
        "FANOUT_JITTER_WINDOW_MS": "300000",
        // IndexNow always attempts now, but the helper short-circuits on
        // INDEXING_DISABLED=true (set in staging), so staging never pings.
        // See workers/api/src/lib/indexnow.ts.
        "WEB_BASE_URL": "https://releases.sh",
        // Feed content enrichment (#feed-enrich): ON in staging so this is the
        // validation surface before prod flips on. No cron fires here
        // (CRON_ENABLED=false), so the forward poll-fetch path never auto-runs;
        // validate via the admin backfill POST /v1/workflows/enrich-feed-content,
        // which runs regardless of this flag. Reuses the CF creds bound below.
        "FEED_ENRICH_ENABLED": "true",
        "FEED_ENRICH_MAX_PER_FIRE": "10",
        "FEED_THIN_CHARS": "600",
        // Discriminator read by /v1/graphql to gate GraphiQL + introspection.
        "ENVIRONMENT": "staging",
        "WEB_BOT_AUTH_ENABLED": "false",
        "USER_API_KEYS_ENABLED": "false",
        "WELL_KNOWN_MATERIALIZATION_ENABLED": "true",
        // Staging issuer/baseURL — overrides the inherited top-level prod value so
        // createAuth's baseURL and oauthValidAudiences() resolve to the staging
        // origin (OAuth issuer, JWT `aud`, discovery metadata), not api.releases.sh.
        "BETTER_AUTH_URL": "https://api-staging.releases.sh",
        // Staging MCP host as the accepted JWT audience. Mirrors the prod entry;
        // resource-server verification wired in sub-project 5.
        "OAUTH_RESOURCE_AUDIENCES": "https://mcp-staging.releases.sh",
      },
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "released-db-staging",
          "database_id": "68d44939-feab-4fcb-8f4f-19778ca1dee8",
        },
      ],
      // Flagship staging app (separate from prod so flag states are isolated).
      "flagship": [{ "binding": "FLAGS", "app_id": "548a95f1-4f8c-402d-8aa2-1b861523d377" }],
      // KV reuses the preview namespaces — those already exist and aren't
      // bound to prod. Keeps `wrangler dev` and staging in the same cache.
      // ALERT_DEDUP_KV shares the LATEST_CACHE namespace (distinct key prefix).
      "kv_namespaces": [
        { "binding": "EMBED_CACHE", "id": "7737ccafd37a43fc9d2365c9a2d7ebca" },
        { "binding": "LATEST_CACHE", "id": "832712867aff4c91bc11bb3cecd7da9e" },
        { "binding": "ALERT_DEDUP_KV", "id": "832712867aff4c91bc11bb3cecd7da9e" },
      ],
      // Prod R2 bucket is read-shared; staging writes go nowhere destructive
      // because CRON_ENABLED=false prevents the ingest paths that call put().
      // RAW_SNAPSHOTS reuses released-media in staging (no dedicated released-raw
      // bucket there) — staging never runs the backfill workflow, so it's unused.
      "r2_buckets": [
        { "binding": "MEDIA", "bucket_name": "released-media" },
        { "binding": "RAW_SNAPSHOTS", "bucket_name": "released-media" },
      ],
      // Media Transformations binding — see top-level note (#1368).
      "media": { "binding": "MEDIA_TRANSFORM" },
      // Producers only in staging — NO consumers. A Cloudflare queue allows a
      // single consumer worker, and prod's `releases-api` already owns the
      // consumer slot on these shared (un-suffixed) queues; declaring the same
      // consumers here makes staging deploys fail (#1717 regression). Staging is
      // a read-surface with no crons producing digests/release-events, so there
      // is nothing for it to consume anyway. Producers stay so enqueue bindings
      // resolve (they pre-date #1717 for webhook-delivery).
      "queues": {
        "producers": [
          { "binding": "WEBHOOK_DELIVERY_QUEUE", "queue": "webhook-delivery" },
          { "binding": "DIGEST_DELIVERY_QUEUE", "queue": "digest-delivery" },
          { "binding": "RELEASE_EVENTS_QUEUE", "queue": "release-events" },
        ],
      },
      "send_email": [
        { "name": "SEND_EMAIL" },
        {
          "name": "AUTH_EMAIL",
          "allowed_sender_addresses": ["noreply@releases.sh", "digests@releases.sh"],
        },
      ],
      "durable_objects": {
        "bindings": [
          { "class_name": "StatusHub", "name": "STATUS_HUB" },
          { "class_name": "ReleaseHub", "name": "RELEASE_HUB" },
          { "class_name": "SourceActor", "name": "SOURCE_ACTOR" },
          { "class_name": "OrgActor", "name": "ORG_ACTOR" },
        ],
      },
      "migrations": [
        { "new_classes": ["StatusHub"], "tag": "v1" },
        { "new_classes": ["ReleaseHub"], "tag": "v2" },
        { "new_classes": ["SourceActor"], "tag": "v3" },
        { "new_classes": ["OrgActor"], "tag": "v4" },
      ],
      "workflows": [
        {
          "name": "poll-and-fetch-staging",
          "binding": "POLL_AND_FETCH_WORKFLOW",
          "class_name": "PollAndFetchWorkflow",
        },
        {
          "name": "onboard-source-staging",
          "binding": "ONBOARD_SOURCE_WORKFLOW",
          "class_name": "OnboardSourceWorkflow",
        },
        {
          "name": "batch-summarize-staging",
          "binding": "BATCH_SUMMARIZE_WORKFLOW",
          "class_name": "BatchSummarizeWorkflow",
        },
        {
          "name": "firecrawl-ingest-staging",
          "binding": "FIRECRAWL_INGEST_WORKFLOW",
          "class_name": "FirecrawlIngestWorkflow",
        },
        {
          "name": "backfill-source-staging",
          "binding": "BACKFILL_SOURCE_WORKFLOW",
          "class_name": "BackfillSourceWorkflow",
        },
        {
          "name": "batch-enrich-staging",
          "binding": "BATCH_ENRICH_WORKFLOW",
          "class_name": "BatchEnrichWorkflow",
        },
        {
          "name": "overview-regen-staging",
          "binding": "OVERVIEW_REGEN_WORKFLOW",
          "class_name": "OverviewRegenWorkflow",
        },
        {
          "name": "collection-summaries-staging",
          "binding": "COLLECTION_SUMMARIES_WORKFLOW",
          "class_name": "CollectionSummariesWorkflow",
        },
        {
          "name": "media-backfill-staging",
          "binding": "MEDIA_BACKFILL_WORKFLOW",
          "class_name": "MediaBackfillWorkflow",
        },
        {
          "name": "deterministic-update-staging",
          "binding": "DETERMINISTIC_UPDATE_WORKFLOW",
          "class_name": "DeterministicUpdateWorkflow",
        },
      ],
      // Empty cron list. Without this override, Wrangler inherits the
      // top-level schedule and fires scheduled events hourly against staging
      // (CRON_ENABLED=false would short-circuit the handler, but the invocation
      // itself is still pointless).
      "triggers": { "crons": [] },
      // No Vectorize bindings — search degrades to FTS (see search-hybrid.ts).
      "services": [
        {
          "binding": "DISCOVERY_WORKER",
          "service": "releases-discovery-staging",
          "entrypoint": "DiscoveryEntrypoint",
        },
        {
          // Self binding (#1946) — staging self-calls carry the staging access
          // key (attached by the workflow), so they clear the gate.
          "binding": "API_SELF",
          "service": "releases-api-staging",
        },
      ],
      "secrets_store_secrets": [
        {
          "binding": "RELEASED_API_KEY",
          "store_id": "a887a71cab084105b79706df23380723",
          "secret_name": "RELEASED_API_KEY",
        },
        {
          "binding": "RELEASES_API_KEY",
          "store_id": "a887a71cab084105b79706df23380723",
          "secret_name": "RELEASES_API_KEY",
        },
        {
          "binding": "RELEASES_PROXY_KEY",
          "store_id": "a887a71cab084105b79706df23380723",
          "secret_name": "RELEASES_PROXY_KEY",
        },
        {
          "binding": "GITHUB_TOKEN",
          "store_id": "a887a71cab084105b79706df23380723",
          "secret_name": "GITHUB_TOKEN",
        },
        {
          "binding": "VOYAGE_API_KEY",
          "store_id": "a887a71cab084105b79706df23380723",
          "secret_name": "VOYAGER_API_KEY",
        },
        {
          "binding": "ANTHROPIC_API_KEY",
          "store_id": "a887a71cab084105b79706df23380723",
          "secret_name": "ANTHROPIC_API_KEY",
        },
        {
          "binding": "WEBHOOK_HMAC_MASTER",
          "store_id": "a887a71cab084105b79706df23380723",
          "secret_name": "WEBHOOK_HMAC_MASTER",
        },
        {
          "binding": "STAGING_ACCESS_KEY",
          "store_id": "a887a71cab084105b79706df23380723",
          "secret_name": "STAGING_ACCESS_KEY",
        },
        // Better Auth signing secret (human user sessions + OAuth AS). Mirrors
        // the prod binding; resolves the same secret value from the shared
        // store. Without it the deployed staging worker falls back to the
        // default secret and every /api/auth/* + OAuth route 500s, so the
        // staging OAuth smoke can't run.
        {
          "binding": "BETTER_AUTH_SECRET",
          "store_id": "a887a71cab084105b79706df23380723",
          "secret_name": "BETTER_AUTH_SECRET",
        },
        // Bound for parity with prod so wrangler doesn't warn about
        // missing inheritance. The staging var INDEXING_DISABLED=true makes the
        // helper short-circuit before ever calling .get() on this binding.
        {
          "binding": "INDEXNOW_KEY",
          "store_id": "a887a71cab084105b79706df23380723",
          "secret_name": "INDEXNOW_KEY",
        },
        {
          "binding": "AI_GATEWAY_TOKEN",
          "store_id": "a887a71cab084105b79706df23380723",
          "secret_name": "AI_GATEWAY_TOKEN_STAGING",
        },
        // OpenRouter cheap-call lane — account-scoped store, same unsuffixed
        // secret as prod. Inert in staging anyway (CRON_ENABLED=false); bound so
        // manual classifier runs can exercise it.
        {
          "binding": "OPENROUTER_API_KEY",
          "store_id": "a887a71cab084105b79706df23380723",
          "secret_name": "OPENROUTER_API_KEY",
        },
        // Browser-Rendering creds for feed enrichment render escalation
        // (#feed-enrich). Same unsuffixed secret_name the discovery staging
        // block uses — no staging-specific variant exists.
        {
          "binding": "CLOUDFLARE_ACCOUNT_ID",
          "store_id": "a887a71cab084105b79706df23380723",
          "secret_name": "CLOUDFLARE_ACCOUNT_ID",
        },
        {
          "binding": "CLOUDFLARE_API_TOKEN",
          "store_id": "a887a71cab084105b79706df23380723",
          "secret_name": "CLOUDFLARE_API_TOKEN",
        },
        {
          "binding": "WEB_BOT_AUTH_PRIVATE_KEY",
          "store_id": "a887a71cab084105b79706df23380723",
          "secret_name": "WEB_BOT_AUTH_PRIVATE_KEY",
        },
        // Firecrawl monitor management is intentionally prod-only. Staging shares
        // the prod Secrets Store, so binding the same FIRECRAWL_* secrets here
        // would let a staging sync clobber prod monitors (same monitor name) and
        // repoint their webhooks at staging. Staging is a read-surface with no
        // crons or webhooks (see AGENTS.md), so POST /sources/:slug/firecrawl/sync
        // correctly returns api_key_unbound (500) here.
      ],
    },
  },
}
