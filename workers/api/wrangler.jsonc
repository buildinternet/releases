{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "releases-api",
  "main": "src/index.ts",
  "alias": {
    "@releases": "../../src",
    "bun:sqlite": "./src/stubs/bun-sqlite.ts",
  },
  "compatibility_date": "2026-03-27",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "logs": {
      "enabled": true,
      "destinations": ["axiom-logs"],
    },
    "traces": {
      "enabled": true,
      "destinations": ["axiom-traces"],
    },
  },
  "vars": {
    "CRON_ENABLED": "true",
    // Per-cron toggle for the daily scrape-no-feed agent sweep. Both
    // CRON_ENABLED and SCRAPE_AGENT_CRON_ENABLED must be truthy to fire.
    "SCRAPE_AGENT_CRON_ENABLED": "true",
    // Max managed-agent sessions dispatched per sweep. Default 20 once live;
    // first deploy ships at 5 for bounded blast radius (~$1/sweep worst case).
    "SCRAPE_AGENT_MAX_SESSIONS": "5",
    // Feature flag for the Workflows-based scrape-agent sweep (see issue #482).
    // Staging wiring validated in #484 (manual instance trigger, clean
    // completion). Prod flipped to "true" on 2026-04-22. To roll back,
    // flip to "false" — `scrapeAgentSweep()` in cron/ is still the
    // fallback path.
    "SCRAPE_AGENT_USE_WORKFLOW": "true",
    // Feature flag for the Workflows-based poll-and-fetch cron (see issue #486).
    // When true, the hourly cron fans out one POLL_AND_FETCH_WORKFLOW instance
    // per due source (gated by tier: normal=4h, low=24h) so mid-embed 429s no
    // longer silently drop Vectorize rows. Rollback: flip to "false".
    "POLL_FETCH_USE_WORKFLOW": "true",
    // Feature flag for the Workflows-based onboarding tail (see issue #493).
    // When true, `POST /v1/sources` dispatches an `ONBOARD_SOURCE_WORKFLOW`
    // instance for the playbook + embed + backfill chain instead of riding
    // `c.executionCtx.waitUntil(...)`. Rollback: flip to "false" — the inline
    // `waitUntil` fallback is still wired in the route.
    "ONBOARD_USE_WORKFLOW": "true",
    // Feature flag for scrape-no-feed / agent change detection (#517). When
    // true, `queryDueSources` widens its filter to include type IN
    // ('scrape','agent') AND feedUrl IS NULL, and `pollOne` routes each via
    // the detector specified in the playbook's `fetchQuirks` frontmatter
    // (#516). Kill-switch: flip to "false" to revert to feed-only polling.
    "SCRAPE_CHANGE_DETECT_ENABLED": "true",
    // Feature flag for the daily force-drain cron (#518). When true, the
    // 04:00 UTC cron flags stranded scrape/agent sources (unreliable quirk
    // or `last_fetched_at` older than FORCE_DRAIN_STALE_HOURS) so the
    // 01:00 scrape-agent-sweep picks them up tomorrow. Capped at
    // FORCE_SWEEP_MAX_SESSIONS (10/day) so the blast radius is bounded.
    "FORCE_DRAIN_CRON_ENABLED": "true",
    "FORCE_DRAIN_STALE_HOURS": "72",
    "FORCE_SWEEP_MAX_SESSIONS": "10",
    "MEDIA_ORIGIN": "https://media.releases.sh",
    // Embedding provider for semantic search. Default: voyage (voyage-4-lite,
    // requested at 512 dims via output_dimension to match the Vectorize indexes).
    // Switch to "openai" or "workers-ai" requires updating the matching secret.
    "EMBEDDING_PROVIDER": "voyage",
    // Kill-switch for the PUBLIC_RATE_LIMITER binding below. Tune the cap there.
    "RATE_LIMIT_ENABLED": "false",
    // Kill-switch for the per-token TOKEN_RATE_LIMITER binding. Tune the cap there.
    "TOKEN_RATE_LIMIT_ENABLED": "true",
    // Email notifications (see src/lib/email.ts + src/lib/notifications.ts).
    // Recipient must be verified in Cloudflare Email Routing; sender domain
    // (releases.sh) must have Email Routing enabled.
    "EMAIL_NOTIFY_ENABLED": "true",
    "EMAIL_NOTIFY_TO": "zach@releases.sh",
    "EMAIL_FROM": "notifications@releases.sh",
    "ADMIN_BASE_URL": "https://api.releases.sh",
    // Event-driven KV purge of GET /v1/releases/latest. Ships "false" to
    // run the helper in shadow mode (log-only); flip to "true" after a
    // week of parity-check logs. See #408.
    "INVALIDATION_ENABLED": "false",
    // Managed-agents errata memory store — destination for POST /v1/errata/:orgId
    // writes. Discovery worker binds tool-notes separately; the API worker only
    // touches errata. See #537.
    "MEMORY_STORE_ERRATA_ID": "memstore_012MKStcUM7QxW9qPCLQtwwt",
    // Retention window for `search_queries` rows. Rows older than this many days
    // are deleted by the nightly 05:00 UTC sweep (see issue #575). Default 90.
    "SEARCH_QUERY_RETENTION_DAYS": "90",
    // Route Anthropic SDK calls through Cloudflare AI Gateway.
    // See docs/architecture/ai-gateway.md. Gateway runs in authenticated
    // mode — the AI_GATEWAY_TOKEN secret below must be bound.
    "ANTHROPIC_BASE_URL": "https://gateway.ai.cloudflare.com/v1/b082600d280d44fd5da3501bc1bffe2f/releases/anthropic",
    // Smear window for the per-source jitter at the head of PollAndFetchWorkflow.
    // Set to "0" to disable; see FANOUT_JITTER_WINDOW_MAX_MS for the upper clamp.
    // See workers/api/src/workflows/poll-and-fetch.ts.
    "FANOUT_JITTER_WINDOW_MS": "300000",
    // Batch summarization workflow (issue #971). Enabled — daily 04:30 UTC cron
    // walks the past 24h of releases across orgs with auto_generate_content=true
    // (~26 orgs as of enable). Admin POST trigger
    // (POST /v1/workflows/batch-summarize) runs unconditionally regardless of
    // this flag.
    "BATCH_SUMMARIZE_ENABLED": "true",
    // Per-run cost ceiling in USD. Pre-submission cost estimate (from body
    // token counts + batch discount) must stay under this value or the workflow
    // aborts with NonRetryableError before submitting anything to Anthropic.
    "BATCH_SUMMARIZE_MAX_COST_USD": "10",
    // Batch overview workflow — admin POST trigger only for now (no cron entry).
    // Self-gates via BATCH_OVERVIEW_ENABLED on any future cron path; admin POST
    // (POST /v1/workflows/batch-overview) runs unconditionally regardless.
    // Replacement candidate for the existing weekly managed-agent regen routine
    // and the operator's Monday top-off runs.
    "BATCH_OVERVIEW_ENABLED": "false",
    "BATCH_OVERVIEW_MAX_COST_USD": "5",
    // Public web origin used to build canonical URLs for IndexNow pings (#649).
    "WEB_BASE_URL": "https://releases.sh",
    // IndexNow ingest pings (#649). On in prod; staging stays off. The
    // ownership file is served by web/src/proxy.ts at /{INDEXNOW_KEY}.txt.
    "INDEXNOW_ENABLED": "true",
    // Feed content enrichment (#feed-enrich). When a feed item arrives
    // summary-only, follow its link and capture the full article via cheap
    // fetch → AI extract, escalating to Cloudflare Browser Rendering only when
    // the result is still thin. Enabled in prod after staging validation
    // (#1109 follow-up). The forward path is cron-gated (poll-fetch); the admin
    // backfill POST /v1/workflows/enrich-feed-content runs regardless.
    // FEED_ENRICH_MAX_PER_FIRE caps enrich attempts per source per cron fire;
    // FEED_THIN_CHARS is the char floor below which a body counts as "thin".
    "FEED_ENRICH_ENABLED": "true",
    "FEED_ENRICH_MAX_PER_FIRE": "10",
    "FEED_THIN_CHARS": "600",
    // Discriminator read by /v1/graphql to gate GraphiQL + introspection.
    // Production deploys advertise "production"; the staging block overrides
    // to "staging".
    "ENVIRONMENT": "production",
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "released-db",
      "database_id": "73be1562-d900-4e25-a62b-650ab74488b7",
    },
  ],
  // Vectorize indexes for semantic search. Provision once via
  // scripts/create-vectorize-indexes.sh before first deploy.
  "vectorize": [
    { "binding": "RELEASES_INDEX", "index_name": "releases-v1" },
    { "binding": "ENTITIES_INDEX", "index_name": "entities-v1" },
    { "binding": "CHANGELOG_CHUNKS_INDEX", "index_name": "changelog-chunks-v1" },
  ],
  // KV namespaces. LATEST_CACHE fronts GET /v1/releases/latest with a
  // 300s TTL (keys: latest:v2:<sorted-qs>). Optional — `withLatestCache`
  // degrades to pass-through when the binding is absent.
  // ALERT_DEDUP_KV stores 1h dedup keys for Tier-1 alert emails (keys:
  // alert:<subject>). Reuses the LATEST_CACHE namespace to avoid provisioning
  // a new resource — alert keys use a distinct prefix so they never collide.
  "kv_namespaces": [
    {
      "binding": "EMBED_CACHE",
      "id": "93b87ae5e253445cabbaaa7a71264915",
      "preview_id": "7737ccafd37a43fc9d2365c9a2d7ebca",
    },
    {
      "binding": "LATEST_CACHE",
      "id": "178c70f9abd940478d5b5a053bf123bb",
      "preview_id": "832712867aff4c91bc11bb3cecd7da9e",
    },
    {
      "binding": "ALERT_DEDUP_KV",
      "id": "178c70f9abd940478d5b5a053bf123bb",
      "preview_id": "832712867aff4c91bc11bb3cecd7da9e",
    },
  ],
  "services": [
    {
      "binding": "DISCOVERY_WORKER",
      "service": "releases-discovery",
      "entrypoint": "DiscoveryEntrypoint",
    },
  ],
  "r2_buckets": [
    {
      "binding": "MEDIA",
      "bucket_name": "released-media",
    },
  ],
  "queues": {
    "producers": [{ "binding": "WEBHOOK_DELIVERY_QUEUE", "queue": "webhook-delivery" }],
  },
  // Email send binding. Omitting `destination_address` keeps the binding open
  // to any destination verified on the account, so EMAIL_NOTIFY_TO can be
  // changed via vars without a binding rename. Pin it if we ever want to
  // narrow the blast radius at the platform level.
  "send_email": [{ "name": "SEND_EMAIL" }],
  "durable_objects": {
    "bindings": [
      { "class_name": "StatusHub", "name": "STATUS_HUB" },
      { "class_name": "ReleaseHub", "name": "RELEASE_HUB" },
    ],
  },
  "migrations": [
    { "new_classes": ["StatusHub"], "tag": "v1" },
    { "new_classes": ["ReleaseHub"], "tag": "v2" },
  ],
  // Cloudflare Workflows — durable, retriable multi-step pipelines. See
  // workers/api/src/workflows/ and issue #482. Prod-only; staging doesn't
  // run crons (see memory: feedback_staging_no_crons.md).
  "workflows": [
    {
      "name": "scrape-agent-sweep",
      "binding": "SCRAPE_AGENT_WORKFLOW",
      "class_name": "ScrapeAgentSweepWorkflow",
    },
    {
      "name": "poll-and-fetch",
      "binding": "POLL_AND_FETCH_WORKFLOW",
      "class_name": "PollAndFetchWorkflow",
    },
    {
      // One instance per hourly cron fire; sleeps 10 min then sends a
      // single [alert] email listing all sources that exhausted retries.
      "name": "poll-fetch-summary",
      "binding": "POLL_FETCH_SUMMARY_WORKFLOW",
      "class_name": "PollFetchSummaryWorkflow",
    },
    {
      // One instance per `POST /v1/sources` create when ONBOARD_USE_WORKFLOW=true.
      // Walks playbook → embed → backfill-fetch with per-step retries. See #493.
      "name": "onboard-source",
      "binding": "ONBOARD_SOURCE_WORKFLOW",
      "class_name": "OnboardSourceWorkflow",
    },
    {
      // Daily batch summarization. Cron fires daily at 04:30 UTC; self-gates via
      // BATCH_SUMMARIZE_ENABLED. Admin POST trigger runs unconditionally. See #971.
      "name": "batch-summarize",
      "binding": "BATCH_SUMMARIZE_WORKFLOW",
      "class_name": "BatchSummarizeWorkflow",
    },
    {
      // Batch overview generation (admin POST trigger only for now). No cron
      // entry until the path is proven against the existing weekly managed-agent
      // regen routine. Per-org request shape with search_result blocks; emits
      // inline citations via Anthropic's citation API (#846).
      "name": "batch-overview",
      "binding": "BATCH_OVERVIEW_WORKFLOW",
      "class_name": "BatchOverviewWorkflow",
    },
  ],
  "routes": [{ "pattern": "api.releases.sh", "custom_domain": true }],
  "triggers": {
    // Hourly: poll feed sources and fetch changed ones.
    // Daily at 01:00 UTC: drain scrape-no-feed sources via managed-agents.
    // Daily at 03:00 UTC: recompute fetchPriority tiers based on cadence.
    // Daily at 04:00 UTC: force-drain stranded scrape/agent sources (#518).
    // Daily at 04:30 UTC: batch summarization (self-gates via BATCH_SUMMARIZE_ENABLED). See #971.
    // Daily at 05:00 UTC: delete search_queries rows older than SEARCH_QUERY_RETENTION_DAYS (#575).
    // Daily at 05:30 UTC: hard-purge tombstoned orgs/sources/products older than TOMBSTONE_RETENTION_DAYS (#666).
    "crons": [
      "0 * * * *",
      "0 1 * * *",
      "0 3 * * *",
      "0 4 * * *",
      "30 4 * * *",
      "0 5 * * *",
      "30 5 * * *",
    ],
  },
  // State is per-colo, not global. `period` must be 10 or 60 (CF constraint).
  "unsafe": {
    "bindings": [
      {
        "name": "PUBLIC_RATE_LIMITER",
        "type": "ratelimit",
        "namespace_id": "1001",
        "simple": { "limit": 120, "period": 60 },
      },
      // Per-token cap for relk_ tokens (root + trusted proxy are exempt).
      // Keyed by tokenId; gated by TOKEN_RATE_LIMIT_ENABLED (default off).
      {
        "name": "TOKEN_RATE_LIMITER",
        "type": "ratelimit",
        "namespace_id": "1002",
        "simple": { "limit": 600, "period": 60 },
      },
    ],
  },
  // Secrets are managed in Cloudflare's Secrets Store (dashboard → Workers → Secrets Store).
  // To rotate or switch providers, update the secret there and redeploy.
  "secrets_store_secrets": [
    {
      "binding": "RELEASED_API_KEY",
      "store_id": "a887a71cab084105b79706df23380723",
      "secret_name": "RELEASED_API_KEY",
    },
    // New-prefix alias of the static root credential. Dual-bound during the
    // RELEASED_->RELEASES_ migration; legacy binding removed in the teardown.
    {
      "binding": "RELEASES_API_KEY",
      "store_id": "a887a71cab084105b79706df23380723",
      "secret_name": "RELEASES_API_KEY",
    },
    // RELEASES_PROXY_KEY exempts the web frontend's server-to-server traffic
    // from the per-IP public rate limiter without unlocking admin content.
    {
      "binding": "RELEASES_PROXY_KEY",
      "store_id": "a887a71cab084105b79706df23380723",
      "secret_name": "RELEASES_PROXY_KEY",
    },
    {
      "binding": "GITHUB_TOKEN",
      "store_id": "a887a71cab084105b79706df23380723",
      "secret_name": "GITHUB_TOKEN",
    },
    {
      "binding": "VOYAGE_API_KEY",
      "store_id": "a887a71cab084105b79706df23380723",
      "secret_name": "VOYAGER_API_KEY",
    },
    {
      "binding": "ANTHROPIC_API_KEY",
      "store_id": "a887a71cab084105b79706df23380723",
      "secret_name": "ANTHROPIC_API_KEY",
    },
    {
      "binding": "WEBHOOK_HMAC_MASTER",
      "store_id": "a887a71cab084105b79706df23380723",
      "secret_name": "WEBHOOK_HMAC_MASTER",
    },
    {
      "binding": "AI_GATEWAY_TOKEN",
      "store_id": "a887a71cab084105b79706df23380723",
      "secret_name": "AI_GATEWAY_TOKEN",
    },
    // Browser-Rendering-capable credentials for feed enrichment's render
    // escalation (#feed-enrich). Reuses the same Secrets Store entries the
    // discovery worker binds — no new secret values. When absent, enrichment
    // degrades to the cheap fetch+extract path (render escalation is skipped).
    {
      "binding": "CLOUDFLARE_ACCOUNT_ID",
      "store_id": "a887a71cab084105b79706df23380723",
      "secret_name": "CLOUDFLARE_ACCOUNT_ID",
    },
    {
      "binding": "CLOUDFLARE_API_TOKEN",
      "store_id": "a887a71cab084105b79706df23380723",
      "secret_name": "CLOUDFLARE_API_TOKEN",
    },
    // IndexNow ownership key. Provision in Secrets Store before flipping
    // INDEXNOW_ENABLED on. The same value must also live in Vercel env so
    // web/src/proxy.ts can serve the ownership file at /{key}.txt.
    {
      "binding": "INDEXNOW_KEY",
      "store_id": "a887a71cab084105b79706df23380723",
      "secret_name": "INDEXNOW_KEY",
    },
  ],
  // ── Staging environment ──────────────────────────────────────────────
  // Deployed as `releases-api-staging` at api-staging.releases.sh. Points
  // at a separate D1 (released-db-staging) refreshed from prod via the
  // sync-staging-db workflow. Vectorize and the discovery service are
  // intentionally omitted — the search path degrades to FTS, and cron is
  // hard-disabled so staging never writes behind prod's back.
  // Interim access gate: `STAGING_ACCESS_KEY` (see middleware/staging-access.ts)
  // rejects any request missing the `X-Releases-Staging-Key` header. CF Access
  // is still the long-term plan — see issue #444.
  "env": {
    "staging": {
      "name": "releases-api-staging",
      "routes": [{ "pattern": "api-staging.releases.sh", "custom_domain": true }],
      "vars": {
        "CRON_ENABLED": "false",
        "SCRAPE_AGENT_CRON_ENABLED": "false",
        "SCRAPE_AGENT_MAX_SESSIONS": "0",
        // Mirrors the prod flag so wrangler doesn't warn about config
        // drift. Not read in staging (no cron → no `scheduled()` event).
        "SCRAPE_AGENT_USE_WORKFLOW": "false",
        // Mirrors prod flag; not read in staging (CRON_ENABLED=false). See #486.
        "POLL_FETCH_USE_WORKFLOW": "false",
        // Mirrors prod flag. Onboarding is request-path (not cron-gated), so this
        // does flip behavior in staging if turned on — leave at "false" until
        // staging-side validation is needed. See #493.
        "ONBOARD_USE_WORKFLOW": "false",
        // Mirrors prod default; not read in staging (CRON_ENABLED=false). See #517.
        "SCRAPE_CHANGE_DETECT_ENABLED": "false",
        // Off in staging — CRON_ENABLED=false means no cron fires anyway, but
        // keep the flag explicitly off so an accidental staging cron flip
        // doesn't dispatch managed-agent sessions against staging. See #518.
        "FORCE_DRAIN_CRON_ENABLED": "false",
        "FORCE_DRAIN_STALE_HOURS": "72",
        "FORCE_SWEEP_MAX_SESSIONS": "10",
        "MEDIA_ORIGIN": "https://media.releases.sh",
        "EMBEDDING_PROVIDER": "voyage",
        "RATE_LIMIT_ENABLED": "false",
        "TOKEN_RATE_LIMIT_ENABLED": "false",
        "EMAIL_NOTIFY_ENABLED": "false",
        "EMAIL_NOTIFY_TO": "zach@releases.sh",
        "EMAIL_FROM": "notifications@releases.sh",
        "ADMIN_BASE_URL": "https://api-staging.releases.sh",
        "INVALIDATION_ENABLED": "false",
        "MEMORY_STORE_ERRATA_ID": "memstore_01BWRxdBdkPbBWcxmKoVGEA9",
        // Mirrors prod default; not read in staging (CRON_ENABLED=false). See #575.
        "SEARCH_QUERY_RETENTION_DAYS": "90",
        // Staging-only: emit X-Robots-Tag: noindex on every response and
        // serve a deny-all /robots.txt. Belt-and-suspenders against the
        // staging hostname getting crawled while it sits unprotected.
        "INDEXING_DISABLED": "true",
        // Route Anthropic SDK calls through Cloudflare AI Gateway.
        // See docs/architecture/ai-gateway.md. Flip on prod after staging burn-in.
        "ANTHROPIC_BASE_URL": "https://gateway.ai.cloudflare.com/v1/b082600d280d44fd5da3501bc1bffe2f/releases-staging/anthropic",
        // Mirrors prod flag; not read in staging (CRON_ENABLED=false). See #971.
        "BATCH_SUMMARIZE_ENABLED": "false",
        "BATCH_SUMMARIZE_MAX_COST_USD": "10",
        // Batch overview workflow — same staging posture as batch-summarize:
        // off-by-default for any cron path, admin POST trigger usable for
        // wiring validation only (CRON_ENABLED=false on staging).
        "BATCH_OVERVIEW_ENABLED": "false",
        "BATCH_OVERVIEW_MAX_COST_USD": "5",
        // Mirrors prod default; not read in staging (CRON_ENABLED=false means no
        // cron fires, so PollAndFetchWorkflow instances are never dispatched).
        "FANOUT_JITTER_WINDOW_MS": "300000",
        // Mirrors prod default; the helper also short-circuits on
        // INDEXING_DISABLED=true, so even if this is flipped on, staging
        // never fires. See workers/api/src/lib/indexnow.ts.
        "WEB_BASE_URL": "https://releases.sh",
        "INDEXNOW_ENABLED": "false",
        // Feed content enrichment (#feed-enrich): ON in staging so this is the
        // validation surface before prod flips on. No cron fires here
        // (CRON_ENABLED=false), so the forward poll-fetch path never auto-runs;
        // validate via the admin backfill POST /v1/workflows/enrich-feed-content,
        // which runs regardless of this flag. Reuses the CF creds bound below.
        "FEED_ENRICH_ENABLED": "true",
        "FEED_ENRICH_MAX_PER_FIRE": "10",
        "FEED_THIN_CHARS": "600",
        // Discriminator read by /v1/graphql to gate GraphiQL + introspection.
        "ENVIRONMENT": "staging",
      },
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "released-db-staging",
          "database_id": "68d44939-feab-4fcb-8f4f-19778ca1dee8",
        },
      ],
      // KV reuses the preview namespaces — those already exist and aren't
      // bound to prod. Keeps `wrangler dev` and staging in the same cache.
      // ALERT_DEDUP_KV shares the LATEST_CACHE namespace (distinct key prefix).
      "kv_namespaces": [
        { "binding": "EMBED_CACHE", "id": "7737ccafd37a43fc9d2365c9a2d7ebca" },
        { "binding": "LATEST_CACHE", "id": "832712867aff4c91bc11bb3cecd7da9e" },
        { "binding": "ALERT_DEDUP_KV", "id": "832712867aff4c91bc11bb3cecd7da9e" },
      ],
      // Prod R2 bucket is read-shared; staging writes go nowhere destructive
      // because CRON_ENABLED=false prevents the ingest paths that call put().
      "r2_buckets": [{ "binding": "MEDIA", "bucket_name": "released-media" }],
      "queues": {
        "producers": [{ "binding": "WEBHOOK_DELIVERY_QUEUE", "queue": "webhook-delivery" }],
      },
      "send_email": [{ "name": "SEND_EMAIL" }],
      "durable_objects": {
        "bindings": [
          { "class_name": "StatusHub", "name": "STATUS_HUB" },
          { "class_name": "ReleaseHub", "name": "RELEASE_HUB" },
        ],
      },
      "migrations": [
        { "new_classes": ["StatusHub"], "tag": "v1" },
        { "new_classes": ["ReleaseHub"], "tag": "v2" },
      ],
      // Workflow binding for on-demand validation only — no cron trigger
      // fires it. Kick a manual instance via:
      //   bunx wrangler workflows trigger scrape-agent-sweep-staging \
      //     --config workers/api/wrangler.jsonc --env staging \
      //     '{"scheduledTime": <unix-ms>}'
      // Staging `CRON_ENABLED=false` short-circuits the workflow at
      // `run()`, so manual triggers only validate wiring (deploy shape +
      // workflow binding surface), not pipeline behavior. See issue #482.
      "workflows": [
        {
          "name": "scrape-agent-sweep-staging",
          "binding": "SCRAPE_AGENT_WORKFLOW",
          "class_name": "ScrapeAgentSweepWorkflow",
        },
        {
          "name": "poll-and-fetch-staging",
          "binding": "POLL_AND_FETCH_WORKFLOW",
          "class_name": "PollAndFetchWorkflow",
        },
        {
          "name": "poll-fetch-summary-staging",
          "binding": "POLL_FETCH_SUMMARY_WORKFLOW",
          "class_name": "PollFetchSummaryWorkflow",
        },
        {
          "name": "onboard-source-staging",
          "binding": "ONBOARD_SOURCE_WORKFLOW",
          "class_name": "OnboardSourceWorkflow",
        },
        {
          "name": "batch-summarize-staging",
          "binding": "BATCH_SUMMARIZE_WORKFLOW",
          "class_name": "BatchSummarizeWorkflow",
        },
        {
          "name": "batch-overview-staging",
          "binding": "BATCH_OVERVIEW_WORKFLOW",
          "class_name": "BatchOverviewWorkflow",
        },
      ],
      // Empty cron list. Without this override, Wrangler inherits the
      // top-level schedule and fires scheduled events hourly against staging
      // (CRON_ENABLED=false would short-circuit the handler, but the invocation
      // itself is still pointless).
      "triggers": { "crons": [] },
      // No Vectorize bindings — search degrades to FTS (see search-hybrid.ts).
      "services": [
        {
          "binding": "DISCOVERY_WORKER",
          "service": "releases-discovery-staging",
          "entrypoint": "DiscoveryEntrypoint",
        },
      ],
      "secrets_store_secrets": [
        {
          "binding": "RELEASED_API_KEY",
          "store_id": "a887a71cab084105b79706df23380723",
          "secret_name": "RELEASED_API_KEY",
        },
        {
          "binding": "RELEASES_API_KEY",
          "store_id": "a887a71cab084105b79706df23380723",
          "secret_name": "RELEASES_API_KEY",
        },
        {
          "binding": "RELEASES_PROXY_KEY",
          "store_id": "a887a71cab084105b79706df23380723",
          "secret_name": "RELEASES_PROXY_KEY",
        },
        {
          "binding": "GITHUB_TOKEN",
          "store_id": "a887a71cab084105b79706df23380723",
          "secret_name": "GITHUB_TOKEN",
        },
        {
          "binding": "VOYAGE_API_KEY",
          "store_id": "a887a71cab084105b79706df23380723",
          "secret_name": "VOYAGER_API_KEY",
        },
        {
          "binding": "ANTHROPIC_API_KEY",
          "store_id": "a887a71cab084105b79706df23380723",
          "secret_name": "ANTHROPIC_API_KEY",
        },
        {
          "binding": "WEBHOOK_HMAC_MASTER",
          "store_id": "a887a71cab084105b79706df23380723",
          "secret_name": "WEBHOOK_HMAC_MASTER",
        },
        {
          "binding": "STAGING_ACCESS_KEY",
          "store_id": "a887a71cab084105b79706df23380723",
          "secret_name": "STAGING_ACCESS_KEY",
        },
        // Bound for parity with prod so wrangler doesn't warn about
        // missing inheritance. The staging vars keep INDEXNOW_ENABLED=false
        // and INDEXING_DISABLED=true, so the helper short-circuits before
        // ever calling .get() on this binding.
        {
          "binding": "INDEXNOW_KEY",
          "store_id": "a887a71cab084105b79706df23380723",
          "secret_name": "INDEXNOW_KEY",
        },
        {
          "binding": "AI_GATEWAY_TOKEN",
          "store_id": "a887a71cab084105b79706df23380723",
          "secret_name": "AI_GATEWAY_TOKEN_STAGING",
        },
        // Browser-Rendering creds for feed enrichment render escalation
        // (#feed-enrich). Same unsuffixed secret_name the discovery staging
        // block uses — no staging-specific variant exists.
        {
          "binding": "CLOUDFLARE_ACCOUNT_ID",
          "store_id": "a887a71cab084105b79706df23380723",
          "secret_name": "CLOUDFLARE_ACCOUNT_ID",
        },
        {
          "binding": "CLOUDFLARE_API_TOKEN",
          "store_id": "a887a71cab084105b79706df23380723",
          "secret_name": "CLOUDFLARE_API_TOKEN",
        },
      ],
    },
  },
}
