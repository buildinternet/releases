{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "releases-api",
  "main": "src/index.ts",
  "alias": {
    "@releases": "../../src",
    "bun:sqlite": "./src/stubs/bun-sqlite.ts"
  },
  "compatibility_date": "2026-03-27",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "vars": {
    "CRON_ENABLED": "true",
    // Per-cron toggle for the daily scrape-no-feed agent sweep. Both
    // CRON_ENABLED and SCRAPE_AGENT_CRON_ENABLED must be truthy to fire.
    "SCRAPE_AGENT_CRON_ENABLED": "true",
    // Max managed-agent sessions dispatched per sweep. Default 20 once live;
    // first deploy ships at 5 for bounded blast radius (~$1/sweep worst case).
    "SCRAPE_AGENT_MAX_SESSIONS": "5",
    "MEDIA_ORIGIN": "https://media.releases.sh",
    // Embedding provider for semantic search. Default: voyage (voyage-4-lite,
    // requested at 512 dims via output_dimension to match the Vectorize indexes).
    // Switch to "openai" or "workers-ai" requires updating the matching secret.
    "EMBEDDING_PROVIDER": "voyage",
    // Kill-switch for the PUBLIC_RATE_LIMITER binding below. Tune the cap there.
    "RATE_LIMIT_ENABLED": "false"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "released-db",
      "database_id": "73be1562-d900-4e25-a62b-650ab74488b7"
    }
  ],
  // Vectorize indexes for semantic search. Provision once via
  // scripts/create-vectorize-indexes.sh before first deploy.
  "vectorize": [
    { "binding": "RELEASES_INDEX", "index_name": "releases-v1" },
    { "binding": "ENTITIES_INDEX", "index_name": "entities-v1" },
    { "binding": "CHANGELOG_CHUNKS_INDEX", "index_name": "changelog-chunks-v1" }
  ],
  // KV namespaces. LATEST_CACHE fronts GET /v1/releases/latest with a
  // 60s TTL (keys: latest:v1:<sorted-qs>). Optional — `withLatestCache`
  // degrades to pass-through when the binding is absent.
  "kv_namespaces": [
    {
      "binding": "EMBED_CACHE",
      "id": "93b87ae5e253445cabbaaa7a71264915",
      "preview_id": "7737ccafd37a43fc9d2365c9a2d7ebca"
    },
    {
      "binding": "LATEST_CACHE",
      "id": "178c70f9abd940478d5b5a053bf123bb",
      "preview_id": "832712867aff4c91bc11bb3cecd7da9e"
    }
  ],
  "services": [
    { "binding": "DISCOVERY_WORKER", "service": "releases-discovery" }
  ],
  "r2_buckets": [
    {
      "binding": "MEDIA",
      "bucket_name": "released-media"
    }
  ],
  "queues": {
    "producers": [
      { "binding": "WEBHOOK_DELIVERY_QUEUE", "queue": "webhook-delivery" }
    ]
  },
  "durable_objects": {
    "bindings": [
      { "class_name": "StatusHub", "name": "STATUS_HUB" },
      { "class_name": "ReleaseHub", "name": "RELEASE_HUB" }
    ]
  },
  "migrations": [
    { "new_classes": ["StatusHub"], "tag": "v1" },
    { "new_classes": ["ReleaseHub"], "tag": "v2" }
  ],
  "routes": [
    { "pattern": "api.releases.sh", "custom_domain": true }
  ],
  "triggers": {
    // Hourly: poll feed sources and fetch changed ones.
    // Daily at 03:00 UTC: recompute fetchPriority tiers based on cadence.
    // Daily at 01:00 UTC: drain scrape-no-feed sources via managed-agents.
    "crons": ["0 * * * *", "0 3 * * *", "0 1 * * *"]
  },
  // State is per-colo, not global. `period` must be 10 or 60 (CF constraint).
  "unsafe": {
    "bindings": [
      {
        "name": "PUBLIC_RATE_LIMITER",
        "type": "ratelimit",
        "namespace_id": "1001",
        "simple": { "limit": 120, "period": 60 }
      }
    ]
  },
  // Secrets are managed in Cloudflare's Secrets Store (dashboard → Workers → Secrets Store).
  // To rotate or switch providers, update the secret there and redeploy.
  "secrets_store_secrets": [
    { "binding": "RELEASED_API_KEY", "store_id": "a887a71cab084105b79706df23380723", "secret_name": "RELEASED_API_KEY" },
    { "binding": "GITHUB_TOKEN", "store_id": "a887a71cab084105b79706df23380723", "secret_name": "GITHUB_TOKEN" },
    { "binding": "VOYAGE_API_KEY", "store_id": "a887a71cab084105b79706df23380723", "secret_name": "VOYAGER_API_KEY" },
    { "binding": "ANTHROPIC_API_KEY", "store_id": "a887a71cab084105b79706df23380723", "secret_name": "ANTHROPIC_API_KEY" },
    { "binding": "WEBHOOK_HMAC_MASTER", "store_id": "a887a71cab084105b79706df23380723", "secret_name": "WEBHOOK_HMAC_MASTER" }
  ]
}
