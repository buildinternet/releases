{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "lib": ["ESNext"],
    "types": ["@cloudflare/workers-types"],
    "paths": {
      "@releases/core/*": ["../../packages/core/src/*"],
      "@releases/adapters/*": ["../../packages/adapters/src/*", "../../src/adapters/*"],
      "@releases/*": ["../../src/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "files": ["../../src/lib/formatters.ts", "../../src/api/types.ts", "../../src/ai/evaluate.ts", "../../src/lib/providers.ts", "../../src/adapters/feed.ts"]
}
