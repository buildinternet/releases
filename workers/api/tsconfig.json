{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "lib": ["ESNext"],
    "types": ["@cloudflare/workers-types", "bun"],
    "paths": {
      "@buildinternet/releases-lib/*": ["../../packages/lib/src/*"],
      "@releases/core-internal/*": ["../../packages/core/src/*"],
      "@releases/ai-internal/*": ["../../packages/ai/src/*"],
      "@releases/adapters/*": ["../../packages/adapters/src/*"],
      "@releases/lib/*": ["../../packages/lib/src/*"],
      "@releases/*": ["../../src/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "files": ["../../packages/lib/src/formatters.ts"]
}
