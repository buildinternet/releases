{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "lib": ["ESNext"],
    "types": ["@cloudflare/workers-types"],
    "paths": {
      "@releases/core/*": ["../../packages/core/src/*"],
      "@releases/adapters/*": ["../../packages/adapters/src/*", "../../src/adapters/*"],
      "@releases/*": ["../../src/*"],
      "drizzle-orm": ["../../node_modules/drizzle-orm"],
      "drizzle-orm/*": ["../../node_modules/drizzle-orm/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "files": ["../../src/api/types.ts"]
}
