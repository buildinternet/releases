{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "lib": ["ESNext"],
    "types": ["@cloudflare/workers-types"],
    "paths": {
      "@buildinternet/releases-lib/*": ["../../packages/lib/src/*"],
      "@releases/core-internal/*": ["../../packages/core/src/*"],
      "@releases/adapters/*": ["../../packages/adapters/src/*"],
      "@releases/lib/*": ["../../packages/lib/src/*"],
      "@releases/*": ["../../src/*"],
      "drizzle-orm": ["../../node_modules/drizzle-orm"],
      "drizzle-orm/*": ["../../node_modules/drizzle-orm/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "files": ["../../src/api/types.ts"]
}
