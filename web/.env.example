# Releases API URL — defaults to localhost for local development
RELEASES_API_URL=https://api.releases.sh

# Admin bearer — used only by dev-gated admin views (status dashboard, org
# fetch-log tab) via the server-side /api/admin/* proxy. Never forwarded on
# public-read calls, so it doesn't leak admin-gated fields into the public
# cache. Unset in production unless you're exposing the dev dashboard.
# RELEASES_API_KEY=

# Trusted-proxy secret — forwarded as X-Releases-Proxy-Key on every
# server-to-server call to the API. Only exempts traffic from the per-IP
# public rate limiter; does NOT unlock admin content. Must match the
# RELEASES_PROXY_KEY secret configured on the API worker.
# RELEASES_PROXY_KEY=

# Enable dev-only status dashboard (set to "true" to enable)
# RELEASES_DEV_MODE=true

# Serve release-feed thumbnails through Cloudflare Image Transformations
# (downscaled, format-negotiated) instead of shipping the full-resolution
# original. Default off — leave unset until cross-origin transforms are enabled
# on the media.releases.sh zone (Cloudflare → Images → Transformations →
# allowed origins), or thumbnails will 403 and fall back to placeholders.
# Build-time inlined (NEXT_PUBLIC_*); set in the Vercel project env.
# NEXT_PUBLIC_RELEASES_IMG_TRANSFORM=true

# Better Auth client base URL — the API worker origin where the auth handler lives
# (prod: https://api.releases.sh, local portless: https://api.releases.localhost).
# This is the PREREQUISITE that reveals the human-auth UI (header sign-in/account
# control, /login + /signup, password reset, passkeys): without it the Better Auth
# client resolves /api/auth/* against the web origin and every session check 404s,
# so the surface stays dark. The auth UI is no longer behind a separate feature flag
# — it follows whether this is set. Build-time inlined (NEXT_PUBLIC_*); set in Vercel.
# NEXT_PUBLIC_BETTER_AUTH_URL=https://api.releases.sh

# Surface the passwordless "Email me a sign-in link" button on the login/signup
# forms. The API worker registers the magic-link endpoints unconditionally; this
# only controls whether the UI advertises them, so the feature can ship dark and
# flip on later. Set to "true" to enable. Build-time inlined; set in Vercel.
# NEXT_PUBLIC_AUTH_MAGIC_LINK=true

# Social sign-in buttons to surface, comma-separated (e.g. "google,github"). The
# client half of the server's social-provider seam — only lists buttons; the
# worker still gates each provider on its credential pair resolving. Unset →
# email/password only. Build-time inlined; set in Vercel.
# NEXT_PUBLIC_AUTH_SOCIAL_PROVIDERS=google,github

# Reveal the self-serve API Keys panel at /account (web). Keep off until the
# server-side `user-api-keys-enabled` Flagship flag is on. Default: off.
NEXT_PUBLIC_USER_API_KEYS=false

# Reveal the device-authorization pages at /device + /device/approve (the browser
# half of `releases login`). The backend always registers the device plugin, so
# this flag alone gates whether the pages are revealed. Default: off.
NEXT_PUBLIC_DEVICE_AUTH_ENABLED=false
