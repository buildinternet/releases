{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "arrowParens": "always",
  "endOfLine": "lf",
  "sortPackageJson": false,
  "ignorePatterns": [
    ".claude",
    "node_modules",
    "dist",
    ".wrangler",
    ".next",
    "web/.next",
    "web/next-env.d.ts",
    "**/*.d.ts",
    "bun.lock",
    "package-lock.json",
    "**/migrations/**/*.sql",
    "plugins/claude-code/skills",
    "packages/*/dist",
    "tests/evals/fixtures/tool-ux/runs",
    "packages/api-types/graphql/schema.graphql",
    "CHANGELOG.md",
    "plans"
  ]
}
