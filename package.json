    "@anthropic-ai/sdk": "^0.80.0",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "dayjs": "^1.11.20",
    "drizzle-orm": "^0.45.1",
    "nanoid": "^5.1.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.3.11",
    "better-sqlite3": "^12.8.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.2"
  }
