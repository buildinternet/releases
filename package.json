{
  "name": "releases",
  "version": "0.13.0",
  "private": true,
  "description": "Changelog indexer and registry for AI agents and developers",
  "type": "module",
  "scripts": {
    "bootstrap": "./scripts/bootstrap.sh",
    "doctor": "./scripts/doctor.sh",
    "dev:web": "cd web && portless run --name ${PORTLESS_NAME:-releases} sh -c 'bun run dev -- --port $PORT'",
    "dev:api": "bun run db:migrate:local && portless run --name api.${PORTLESS_NAME:-releases} sh -c 'wrangler dev --config workers/api/wrangler.jsonc --port $PORT --ip 127.0.0.1'",
    "dev:discovery": "portless run --name discovery.${PORTLESS_NAME:-releases} sh -c 'wrangler dev --config workers/discovery/wrangler.jsonc --port $PORT --ip 127.0.0.1'",
    "dev:mcp": "portless run --name mcp.${PORTLESS_NAME:-releases} sh -c 'wrangler dev --config workers/mcp/wrangler.jsonc --port $PORT --ip 127.0.0.1'",
    "dev:portless:doctor": "portless doctor",
    "preview:web": "cd web && RELEASES_API_URL=${RELEASES_API_URL:-${RELEASED_API_URL:-http://localhost:8787}} bun run dev -- --port 3000",
    "preview:api": "wrangler dev --config workers/api/wrangler.jsonc --port 8787 --ip 127.0.0.1",
    "preview:mcp": "wrangler dev --config workers/mcp/wrangler.jsonc --port 8788 --ip 127.0.0.1",
    "preview:discovery": "wrangler dev --config workers/discovery/wrangler.jsonc --port 8789 --ip 127.0.0.1",
    "mcp:ui:install": "cd workers/mcp/ui && bun install",
    "mcp:ui:build": "cd workers/mcp/ui && bun install --silent && bun run build",
    "mcp:ui:build:dev": "cd workers/mcp/ui && bun install --silent && NODE_ENV=development bun run build",
    "mcp:ui:watch": "cd workers/mcp/ui && bun install --silent && bun run build:watch",
    "mcp:ui:typecheck": "cd workers/mcp/ui && bun run typecheck",
    "mcp:inspect:local": "npx @modelcontextprotocol/inspector npx mcp-remote https://mcp.releases.localhost/mcp",
    "mcp:inspect:staging": "sh -c 'test -n \"$STAGING_ACCESS_KEY\" || { echo \"Set STAGING_ACCESS_KEY in .env\" >&2; exit 1; }; npx @modelcontextprotocol/inspector npx mcp-remote https://mcp-staging.releases.sh/mcp --header \"X-Releases-Staging-Key: $STAGING_ACCESS_KEY\"'",
    "mcp:inspect:prod": "npx @modelcontextprotocol/inspector npx mcp-remote https://mcp.releases.sh/mcp",
    "deploy:api": "wrangler deploy --config workers/api/wrangler.jsonc",
    "deploy:discovery": "wrangler deploy --config workers/discovery/wrangler.jsonc",
    "deploy:mcp": "bun run mcp:ui:build && wrangler deploy --config workers/mcp/wrangler.jsonc",
    "publish:mcp-registry": "cd workers/mcp && mcp-publisher publish",
    "deploy:agents": "bun scripts/sync-agent-skills.ts",
    "deploy:agents:discovery": "bun scripts/sync-agent-skills.ts --discovery",
    "deploy:agents:worker": "bun scripts/sync-agent-skills.ts --worker",
    "deploy:agents:coordinator": "bun scripts/sync-agent-skills.ts --coordinator",
    "deploy:skills": "bun scripts/sync-agent-skills.ts --skills",
    "deploy": "bun run deploy:api && bun run deploy:discovery && bun run deploy:mcp",
    "db:generate": "drizzle-kit generate",
    "db:check-filenames": "./scripts/check-migration-filenames.sh",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:local": "wrangler d1 migrations apply released-db --local --config workers/api/wrangler.jsonc",
    "db:reset:local": "rm -rf workers/api/.wrangler/state/v3/d1 && bun run db:migrate:local",
    "db:migrate:remote": "wrangler d1 migrations apply released-db --remote --config workers/api/wrangler.jsonc",
    "db:studio": "bun drizzle-kit studio",
    "db:studio:d1": "bun drizzle-kit studio --config drizzle-d1.config.ts",
    "db:query": "wrangler d1 execute released-db --local --config workers/api/wrangler.jsonc --command",
    "db:pull": "./scripts/db-pull.sh",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "typecheck": "oxlint",
    "check": "bun run lint && bun run format:check",
    "clean:worktrees": "./scripts/clean-worktrees.sh",
    "test": "bun test packages/ && bun test tests/ web/ workers/discovery workers/mcp workers/webhooks && bun test workers/api",
    "eval:article-extract": "bun tests/evals/article-extract.eval.ts",
    "eval:breaking": "bun tests/evals/breaking.eval.ts",
    "eval:collection-summary": "bun tests/evals/collection-summary.eval.ts",
    "eval:evaluation": "bun test ./tests/evals/evaluation.eval.ts --timeout 30000",
    "eval:marketing": "bun tests/evals/marketing-classifier.eval.ts",
    "eval:extraction": "bun tests/evals/extraction.eval.ts",
    "eval:importance": "bun tests/evals/importance.eval.ts",
    "eval:summary": "bun tests/evals/release-summary.eval.ts",
    "eval:overview": "bun tests/evals/overview.eval.ts",
    "eval:search": "bun tests/evals/search.eval.ts",
    "eval:tool-ux-report": "bun tests/evals/tool-ux-report.ts",
    "gen:releases-schema": "bun scripts/gen-releases-json-schema.ts",
    "flags:docs": "bun scripts/gen-flag-docs.ts",
    "smoke:catalog-web": "bun scripts/smoke-catalog-web.ts",
    "changeset": "changeset",
    "changeset:version": "changeset version && bun install",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "oxlint --no-error-on-unmatched-pattern",
      "oxfmt --write --no-error-on-unmatched-pattern",
      "oxfmt --check --no-error-on-unmatched-pattern"
    ],
    "*.{json,jsonc,yml,yaml,css,md,mdx,html}": [
      "oxfmt --write --no-error-on-unmatched-pattern",
      "oxfmt --check --no-error-on-unmatched-pattern"
    ]
  },
  "workspaces": [
    "workers/api",
    "web",
    "packages/*"
  ],
  "catalog": {
    "@anthropic-ai/sdk": "^0.110.0"
  },
  "overrides": {
    "kysely": "^0.28.17"
  },
  "keywords": [
    "changelog",
    "releases",
    "mcp",
    "ai"
  ],
  "author": "Build Internet",
  "license": "Apache-2.0",
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.9",
    "@anthropic-ai/claude-agent-sdk": "^0.3.204",
    "@anthropic-ai/sdk": "catalog:",
    "@buildinternet/releases-api-types": "workspace:*",
    "@buildinternet/releases-core": "workspace:*",
    "@buildinternet/releases-lib": "^0.68.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openrouter/ai-sdk-provider": "^2.10.0",
    "@releases/adapters": "workspace:*",
    "@releases/ai-internal": "workspace:*",
    "@releases/core-internal": "workspace:*",
    "@releases/lib": "workspace:*",
    "@releases/rendering": "workspace:*",
    "@releases/search": "workspace:*",
    "ai": "^7.0.17",
    "dayjs": "^1.11.21",
    "drizzle-orm": "^0.45.2",
    "js-tiktoken": "^1.0.21",
    "nanoid": "^5.1.16",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@types/bun": "^1.3.14",
    "drizzle-kit": "^0.31.10",
    "hono": "^4.12.28",
    "husky": "^9.1.7",
    "jose": "^6.2.3",
    "lint-staged": "^17.0.8",
    "@cloudflare/sandbox": "^0.12.3",
    "@cloudflare/workers-types": "^5.20260707.1",
    "mimetext": "^3.0.24",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "portless": "^0.15.1",
    "typescript": "^6.0.3",
    "wrangler": "^4.108.0",
    "yaml": "^2.9.0"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "bun@1.3.14"
}
