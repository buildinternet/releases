# Required
ANTHROPIC_API_KEY=

# Required for scrape sources (Cloudflare Browser Rendering)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Optional
GITHUB_TOKEN=
RELEASED_DATA_DIR=~/.released
RELEASED_INGEST_MODEL=claude-haiku-4-5-20251001
RELEASED_QUERY_MODEL=claude-sonnet-4-6

# Remote mode (D1) — set both to route CLI operations through the API Worker
# RELEASED_API_URL=https://released-api.rally-workers-test.workers.dev
# RELEASED_API_KEY=

# Remote discovery — set to route `onboard` through the discovery worker (requires remote mode)
# RELEASED_DISCOVERY_URL=https://released-discovery.rally-workers-test.workers.dev
