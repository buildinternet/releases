# Required
ANTHROPIC_API_KEY=

# Optional — route Anthropic calls through Cloudflare AI Gateway for observability,
# caching, and fallback config. See docs/architecture/ai-gateway.md. The gateway
# URL is the Anthropic sub-path from a gateway you've created in the CF dashboard.
# Covers direct SDK calls from workers; managed-agent internal loops bypass it.
# ANTHROPIC_BASE_URL=https://gateway.ai.cloudflare.com/v1/<account-id>/<gateway-id>/anthropic
# AI_GATEWAY_TOKEN=          # only needed when the gateway is in authenticated mode

# Required for scrape sources (Cloudflare Browser Rendering)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Optional
GITHUB_TOKEN=
RELEASES_DATA_DIR=~/.releases
RELEASES_INGEST_MODEL=claude-haiku-4-5-20251001
RELEASES_QUERY_MODEL=claude-sonnet-4-6

# Remote mode (D1) — set both to route CLI operations through the API Worker.
# Compiled binaries default to https://api.releases.sh when RELEASES_API_URL is unset.
# RELEASES_API_URL=https://api.releases.sh
# RELEASES_API_KEY=

# Managed agents — pre-created via Anthropic console. Set these to skip auto-create.
# ANTHROPIC_AGENT_ID=agent_...
# ANTHROPIC_ENVIRONMENT_ID=env_...
# ANTHROPIC_AGENT_VERSION=1

# Managed-agents memory stores — created via `bun scripts/sync-agent-skills.ts
# --memory-stores`. IDs land in scripts/agent-skills.json (prod) or
# scripts/agent-skills.staging.json, and are bound into workers/discovery/
# wrangler.jsonc when session attach lands. Observability via the Anthropic
# console's built-in memory-store browser; not consumed at CLI runtime.
# MEMORY_STORE_ERRATA_ID=memstore_...
# MEMORY_STORE_TOOL_NOTES_ID=memstore_...

# API worker cron vars (set in workers/api/wrangler.jsonc, not here) — documented
# for reference. Both CRON_ENABLED and SCRAPE_AGENT_CRON_ENABLED must be truthy
# for the daily 01:00 UTC scrape-no-feed sweep to fire.
# SCRAPE_AGENT_CRON_ENABLED=true
# SCRAPE_AGENT_MAX_SESSIONS=5     # bounded-rollout default; bump to 20 once healthy
# SEARCH_QUERY_RETENTION_DAYS=90  # nightly 05:00 UTC sweep deletes rows older than this many days

# Tier-1 alert notifications (see workers/api/src/lib/send-alert.ts).
# EMAIL_NOTIFY_ENABLED, EMAIL_NOTIFY_TO, and EMAIL_FROM are set in wrangler.jsonc.
# ALERT_DEDUP_KV reuses the LATEST_CACHE KV namespace (no new resource needed).
# In the webhooks worker the same EMAIL_NOTIFY_* vars control auto-disable / DLQ alerts.

# scripts/eval-release-content-providers.ts (issue #851) — cross-provider
# model comparison. Reuses ANTHROPIC_API_KEY for the Anthropic Haiku 4.5
# baseline and CLOUDFLARE_ACCOUNT_ID + CLOUDFLARE_API_TOKEN (already
# required above) for the Workers AI providers (Kimi K2.6, GLM-4.7-Flash,
# Qwen3 30B, Llama 4 Scout, GPT-OSS-120B). No third-party keys needed.

# Gate the tool-use loop for extraction of large bodies (>50K tokens). When false,
# every fetch inlines the body into a single /v1/messages call (legacy behavior).
# When true, bodies above the threshold route through a multi-round tool-use loop
# that pulls body slices on demand — drops cost on monolithic JSON/HTML sources
# (e.g. PostHog's 1.26 MB page-data.json). See
# docs/superpowers/specs/2026-04-24-large-body-extract-tool-loop-design.md.
# Per-source override: set source.metadata.extractStrategy = "toolloop".
# EXTRACT_TOOLLOOP_ENABLED=false

# Feed content enrichment (#feed-enrich). When a feed item arrives summary-only,
# follow its link and capture the full article — cheap fetch → AI extract,
# escalating to Cloudflare Browser Rendering only when the result is still thin.
# Set in wrangler.jsonc (not .env); shown here for reference. Ships off in prod,
# on in staging. Render escalation reuses CLOUDFLARE_ACCOUNT_ID +
# CLOUDFLARE_API_TOKEN (above); without them, enrichment stays on the cheap path.
# Per-source override: set source.metadata.feedContentDepth = "summary-only".
# FEED_ENRICH_ENABLED=false
# FEED_ENRICH_MAX_PER_FIRE=10  # max enrich attempts per source per cron fire
# FEED_THIN_CHARS=600          # char floor below which a feed body counts as "thin"

# Ingest-time R2 media upload (#1177). When on, the poll-fetch + /releases/batch
# ingest paths drop junk media (favicons/avatars/pixels) and mirror surviving
# images to the `released-media` R2 bucket, stamping each item's r2Key so reads
# serve them same-origin from media.releases.sh. Set in wrangler.jsonc (not
# .env); shown here for reference. Default off — flag-off stores third-party
# URLs verbatim, as before. Uses the existing MEDIA R2 binding (no new secrets).
# MEDIA_R2_UPLOAD_ENABLED=false
