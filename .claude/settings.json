{
  "permissions": {
    "allow": [
      "Bash(npx tsc:*)",
      "Bash(bun test)",
      "Bash(releases list:*)",
      "Bash(releases tail:*)",
      "Bash(releases latest:*)",
      "Bash(releases show:*)",
      "Bash(releases admin source list:*)",
      "mcp__claude-in-chrome__read_page",
      "mcp__claude-in-chrome__tabs_context_mcp",
      "mcp__claude-in-chrome__find"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -d \"$CLAUDE_PROJECT_DIR/node_modules\" ] || (cd \"$CLAUDE_PROJECT_DIR\" && bun install >&2)"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/protect-env.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/protect-env.sh"
          }
        ]
      }
    ]
  }
}
