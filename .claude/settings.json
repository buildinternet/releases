{
  "extraKnownMarketplaces": {
    "releases": {
      "source": { "source": "github", "repo": "buildinternet/releases-cli" }
    }
  },
  "enabledPlugins": { "releases@releases": true },
  "permissions": {
    "allow": [
      "Bash(npx tsc:*)",
      "Bash(bun test)",
      "Bash(releases list:*)",
      "Bash(releases tail:*)",
      "Bash(releases latest:*)",
      "Bash(releases show:*)",
      "Bash(releases admin source list:*)",
      "mcp__claude-in-chrome__read_page",
      "mcp__claude-in-chrome__tabs_context_mcp",
      "mcp__claude-in-chrome__find"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/setup-worktree.sh\" 1>&2",
            "timeout": 600
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/session-teardown.sh\" 1>&2",
            "timeout": 60
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/protect-env.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/protect-env.sh"
          }
        ]
      }
    ]
  }
}
