{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "api",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["run", "dev:api"],
      "port": 8787,
      "autoPort": false
    },
    {
      "name": "web",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["run", "dev:web"],
      "port": 3000,
      "autoPort": true,
      "env": {
        "RELEASED_API_URL": "http://localhost:8787"
      }
    }
  ]
}
